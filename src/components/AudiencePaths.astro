---
---

<section class="max-w-5xl mx-auto px-6 py-20">
  <div class="text-center mb-12">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground">Who I Help</h2>
    <p class="mt-2 text-base text-secondary max-w-xl mx-auto">
      The Love Not Fear operating system meets you where you are.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Individuals -->
    <a
      href="https://lovenotfear.com"
      target="_blank"
      rel="noopener"
      class="group block p-6 border border-border rounded-xl bg-background hover:border-accent/40 hover:shadow-sm transition-all duration-200"
    >
      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
      </div>
      <h3 class="text-base font-semibold text-foreground mb-2 group-hover:text-accent transition-colors">
        Individuals
      </h3>
      <p class="text-sm text-secondary leading-relaxed">
        Find your purpose and build systems for a life you love. Discover your values, craft your vision, and create daily habits that stick.
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm text-accent font-medium">
        Learn more
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </a>

    <!-- Business Leaders -->
    <a
      href="https://lnfpeople.com"
      target="_blank"
      rel="noopener"
      class="group block p-6 border border-border rounded-xl bg-background hover:border-accent/40 hover:shadow-sm transition-all duration-200"
    >
      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
        </svg>
      </div>
      <h3 class="text-base font-semibold text-foreground mb-2 group-hover:text-accent transition-colors">
        Business Leaders
      </h3>
      <p class="text-sm text-secondary leading-relaxed">
        Build teams that operate from love, not fear. Align your organization around purpose and values for conscious, high-performance culture.
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm text-accent font-medium">
        Learn more
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </a>

    <!-- Students -->
    <a
      href="https://lovenotfear.com/students"
      target="_blank"
      rel="noopener"
      class="group block p-6 border border-border rounded-xl bg-background hover:border-accent/40 hover:shadow-sm transition-all duration-200"
    >
      <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
        </svg>
      </div>
      <h3 class="text-base font-semibold text-foreground mb-2 group-hover:text-accent transition-colors">
        Students
      </h3>
      <p class="text-sm text-secondary leading-relaxed">
        Figure out what to study and what to do with your life. Build a foundation of self-awareness before the world tells you who to be.
      </p>
      <span class="inline-flex items-center gap-1 mt-4 text-sm text-accent font-medium">
        Learn more
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </a>
  </div>
</section>
