---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  article?: {
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
  };
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  article,
} = Astro.props;

const siteURL = Astro.site?.href ?? 'https://davidhenzel.com';
const ogImage = new URL(image, siteURL).href;

// JSON-LD: Person schema on all pages
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'David Henzel',
  url: 'https://davidhenzel.com',
  jobTitle: 'Serial Entrepreneur',
  sameAs: [
    'https://twitter.com/davidhenzel',
    'https://www.linkedin.com/in/davidhenzel',
  ],
};

// JSON-LD: Organization schema on all pages
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'David Henzel',
  url: 'https://davidhenzel.com',
  logo: 'https://davidhenzel.com/images/dh-logo.svg',
  founder: {
    '@type': 'Person',
    name: 'David Henzel',
  },
  sameAs: [
    'https://twitter.com/davidhenzel',
    'https://www.linkedin.com/in/davidhenzel',
    'https://www.instagram.com/davidhenzel',
  ],
};

// JSON-LD: BlogPosting schema on blog posts
const blogPostSchema = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      datePublished: article.pubDate.toISOString(),
      ...(article.updatedDate && { dateModified: article.updatedDate.toISOString() }),
      author: {
        '@type': 'Person',
        name: 'David Henzel',
        url: 'https://davidhenzel.com',
      },
      image: ogImage,
      description,
      ...(article.tags?.length && { keywords: article.tags.join(', ') }),
    }
  : null;
---

<!-- Charset & Viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#FFFFFF" />
<meta name="author" content="David Henzel" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />

<!-- Inter Variable Font from Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
  rel="stylesheet"
/>

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
{!article && <meta property="og:type" content="website" />}
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="David Henzel" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:creator" content="@davidhenzel" />

<!-- Article meta (blog posts only) -->
{article && (
  <>
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={article.pubDate.toISOString()} />
    <meta property="article:author" content="David Henzel" />
    {article.tags?.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}

<!-- RSS Autodiscovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="David Henzel Blog"
  href="/rss.xml"
/>

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
{blogPostSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
)}
