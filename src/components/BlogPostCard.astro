---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  heroImage?: string;
}

const { title, date, excerpt, slug, heroImage } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group flex items-start gap-5 py-6 border-b border-neutral-200 last:border-0 hover:opacity-80 transition-opacity"
>
  {heroImage && (
    <img
      src={heroImage}
      alt=""
      class="w-20 h-12 rounded border border-neutral-100 object-cover shrink-0 mt-1"
      loading="lazy"
    />
  )}
  <div class="flex flex-col gap-1.5">
    <time class="text-xs text-neutral-400 uppercase tracking-wide">{formattedDate}</time>
    <h3 class="text-base font-semibold text-neutral-900 group-hover:underline underline-offset-2">
      {title}
    </h3>
    <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2">
      {excerpt}
    </p>
  </div>
</a>
