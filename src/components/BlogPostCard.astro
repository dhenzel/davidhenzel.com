---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  heroImage?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, date, excerpt, slug, heroImage, tags = [], featured = false } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = excerpt.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<a
  href={`/blog/${slug}`}
  class:list={[
    'group block rounded-xl border border-border bg-background overflow-hidden transition-all duration-200 hover:shadow-md hover:shadow-secondary/5',
    featured ? 'col-span-full' : '',
  ]}
>
  {heroImage && (
    <div class:list={[
      'overflow-hidden',
      featured ? 'aspect-[2/1]' : 'aspect-video',
    ]}>
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-200 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </div>
  )}
  <div class:list={[
    'p-5',
    featured ? 'md:p-7' : '',
  ]}>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-[0.6875rem] uppercase tracking-wide text-accent bg-accent/10 px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
    <div class="flex items-center gap-2 text-xs text-secondary mb-2">
      <time>{formattedDate}</time>
      <span aria-hidden="true">&middot;</span>
      <span>{readingTime} min read</span>
    </div>
    <h3 class:list={[
      'font-semibold text-foreground tracking-tight group-hover:text-accent transition-colors mb-2',
      featured ? 'text-xl md:text-2xl' : 'text-base',
    ]}>
      {title}
    </h3>
    <p class:list={[
      'text-sm text-secondary leading-relaxed line-clamp-2',
      featured ? 'md:line-clamp-3' : '',
    ]}>
      {excerpt}
    </p>
  </div>
</a>
