---
import NewsletterForm from './NewsletterForm.astro';
---

<!-- Book Newsletter Popup -->
<div id="book-popup" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="book-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="absolute inset-0 flex items-center justify-center p-6">
    <div class="relative bg-accent-light rounded-xl shadow-2xl max-w-md w-full p-8 border border-border">
      <!-- Close button -->
      <button
        id="book-close"
        class="absolute top-4 right-4 text-secondary hover:text-foreground transition-colors"
        aria-label="Close popup"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="flex items-center gap-3 mb-4">
        <div class="shrink-0 w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <p class="text-xs uppercase tracking-widest text-secondary/60">Coming 2026</p>
      </div>

      <h2 class="text-2xl font-semibold tracking-tight text-foreground mb-3">
        Love Not Fear — The Book
      </h2>
      <p class="text-sm text-secondary leading-relaxed mb-5">
        Be the first to know when it launches. Get behind-the-scenes updates on the writing journey.
      </p>

      <NewsletterForm id="book" />
    </div>
  </div>
</div>

<script>
  const bookPopup = document.getElementById('book-popup');
  const bookBackdrop = document.getElementById('book-backdrop');
  const bookClose = document.getElementById('book-close');
  const bookNotifyBtn = document.getElementById('book-notify-btn');

  function showBookPopup() {
    bookPopup?.classList.remove('hidden');
  }

  function hideBookPopup() {
    bookPopup?.classList.add('hidden');
  }

  bookNotifyBtn?.addEventListener('click', showBookPopup);
  bookBackdrop?.addEventListener('click', hideBookPopup);
  bookClose?.addEventListener('click', hideBookPopup);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !bookPopup?.classList.contains('hidden')) {
      hideBookPopup();
    }
  });
</script>
