---
import { pillarForTags } from '../data/pillars';

interface Props {
  type?: 'newsletter' | 'lnf-course' | 'free-course' | 'community' | 'cohort' | 'retreat' | 'upcoach' | 'context-engine' | 'winback';
  tags?: string[];
}

const { type, tags = [] } = Astro.props;

// Map the post's pillar → the venture it funnels toward.
const pillarToCTA: Record<string, string> = {
  'ai-native-company': 'context-engine',
  'culture-without-fear': 'upcoach',
  'operators-notebook': 'context-engine',
  'founders-operating-system': 'lnf-course',
  'love-vs-fear': 'community',
};

const pillar = pillarForTags(tags);
const ctaType = type || (pillar ? pillarToCTA[pillar.slug] : undefined) || 'context-engine';

const ctas: Record<string, { heading: string; body: string; linkText: string; url: string; external: boolean }> = {
  'context-engine': {
    heading: 'This is what I build all day.',
    body: 'Context Engine is the context layer I actually run, it captures your company\'s knowledge and serves it to any AI tool, so your agents already know your world. Real transformation, not setup porn.',
    linkText: 'See Context Engine',
    url: 'https://contextengine.com',
    external: true,
  },
  'lnf-course': {
    heading: 'I put everything I know into a free course.',
    body: 'Purpose, values, vision, habits. The same operating system that changed how I run my life and my companies. No cost, no catch.',
    linkText: 'Start the free self-leadership course',
    url: 'https://community.lovenotfear.com/c/free-lnf-self-leadership-course',
    external: true,
  },
  'cohort': {
    heading: 'Want to go deeper?',
    body: 'If this resonates, I run small group cohorts where we work through this together. Real people, real conversations, real change.',
    linkText: 'Get in touch to join a cohort',
    url: 'mailto:dh@davidhenzel.com?subject=Cohort%20Inquiry',
    external: false,
  },
  'retreat': {
    heading: 'Come to Bodrum.',
    body: 'I host leadership retreats at my place in Bodrum, Turkey. Small groups, real conversations, nature. The kind of reset that sticks.',
    linkText: 'Learn more about Dünyam Village',
    url: 'https://dunyamvillage.com',
    external: true,
  },
  'upcoach': {
    heading: 'We built a platform for this.',
    body: 'If you run coaching programs or team development, upcoach handles the structure so you can focus on the people.',
    linkText: 'Check out upcoach',
    url: 'https://upcoach.com',
    external: true,
  },
  'free-course': {
    heading: 'The full course is free.',
    body: 'A complete self-leadership course, purpose, values, vision, habits. Everything I wish someone had handed me 20 years ago. Free, self-paced, no strings.',
    linkText: 'Start the free self-leadership course',
    url: 'https://community.lovenotfear.com/c/free-lnf-self-leadership-course',
    external: true,
  },
  'community': {
    heading: 'You don\'t have to figure this out alone.',
    body: 'The Love Not Fear community is where people who think like this hang out. Facilitators, founders, students. Real conversations, no fluff.',
    linkText: 'Join the community',
    url: 'https://community.lovenotfear.com/c/love-not-fear-community',
    external: true,
  },
  'winback': {
    heading: 'Sitting on a pile of lapsed customers?',
    body: 'WinbackEngine puts trained human agents on the phone with the customers who drifted away, and only gets paid on the revenue we actually recover. Guaranteed 5x in the first 30 days or you don\'t pay.',
    linkText: 'See what WinbackEngine can recover',
    url: 'https://winbackengine.com',
    external: true,
  },
};

const cta = ctas[ctaType] ?? ctas['context-engine'];
---

<aside class="my-14 border-t border-border pt-8">
  <p class="font-serif text-xl text-foreground mb-2">{cta.heading}</p>
  <p class="text-sm text-secondary leading-relaxed mb-4 max-w-xl">{cta.body}</p>
  <a
    href={cta.url}
    target={cta.external ? '_blank' : undefined}
    rel={cta.external ? 'noopener' : undefined}
    class="ink-link font-mono text-[0.72rem] uppercase tracking-[0.15em]"
  >
    {cta.linkText} →
  </a>
</aside>
