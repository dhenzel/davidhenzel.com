---
import NewsletterForm from './NewsletterForm.astro';
---

<!-- Exit Intent Newsletter Popup -->
<div id="exit-popup" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="exit-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="absolute inset-0 flex items-center justify-center p-6">
    <div class="relative bg-white rounded-xl shadow-2xl max-w-md w-full p-8">
      <!-- Close button -->
      <button
        id="exit-close"
        class="absolute top-4 right-4 text-neutral-400 hover:text-neutral-900 transition-colors"
        aria-label="Close popup"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-3">Before you go</p>
      <h2 class="text-2xl font-semibold tracking-tight text-neutral-900 mb-3">
        Join the newsletter
      </h2>
      <p class="text-sm text-neutral-500 leading-relaxed mb-5">
        Thoughts on building companies, the Love Not Fear operating system, and what it means to lead with purpose. No spam.
      </p>

      <NewsletterForm id="exit" />
    </div>
  </div>
</div>

<script>
  const popup = document.getElementById('exit-popup');
  const backdrop = document.getElementById('exit-backdrop');
  const closeBtn = document.getElementById('exit-close');
  const STORAGE_KEY = 'dh_exit_popup_shown';

  function showPopup() {
    if (sessionStorage.getItem(STORAGE_KEY)) return;
    popup?.classList.remove('hidden');
    sessionStorage.setItem(STORAGE_KEY, '1');
  }

  function hidePopup() {
    popup?.classList.add('hidden');
  }

  // Exit intent: mouse leaves viewport from top
  document.addEventListener('mouseout', (e) => {
    if (e.clientY <= 0) showPopup();
  });

  // Close on backdrop click or close button
  backdrop?.addEventListener('click', hidePopup);
  closeBtn?.addEventListener('click', hidePopup);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hidePopup();
  });
</script>
