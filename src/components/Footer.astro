---
import { navItems } from '../data/navigation';

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-white">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <!-- Newsletter signup -->
    <div class="mb-8 max-w-sm">
      <p class="text-sm font-semibold text-neutral-900 mb-2">Join the newsletter</p>
      <p class="text-xs text-neutral-500 mb-3">Thoughts on building companies and the Love Not Fear operating system.</p>
      <!-- GHL Form Embed — replace FORM_ID_HERE with your GoHighLevel newsletter form ID -->
      <iframe
        src="https://api.leadconnectorhq.com/widget/form/FORM_ID_HERE"
        style="width:100%;height:120px;border:none;border-radius:3px"
        id="footer-newsletter"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Newsletter"
        data-layout-iframe-id="footer-newsletter"
        data-form-id="FORM_ID_HERE"
        title="Newsletter signup"
      ></iframe>
      <script src="https://link.msgsndr.com/js/form_embed.js"></script>
    </div>

    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <!-- Left: contact & social -->
      <div class="flex flex-col gap-3">
        <a
          href="mailto:dh@davidhenzel.com"
          class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
        >
          dh@davidhenzel.com
        </a>
        <div class="flex items-center gap-4">
          <a
            href="https://twitter.com/davidhenzel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
            aria-label="David Henzel on X (Twitter)"
          >
            X / Twitter
          </a>
          <a
            href="https://www.linkedin.com/in/davidhenzel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
            aria-label="David Henzel on LinkedIn"
          >
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Right: nav repeat -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-neutral-600 hover:text-neutral-900 transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-neutral-200">
      <p class="text-xs text-neutral-400">
        &copy; {year} David Henzel
      </p>
    </div>
  </div>
</footer>
