---
import { navItems } from '../data/navigation';
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-content mx-auto px-6 py-14">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
      <div class="max-w-xs">
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-6 w-auto mb-4" />
        <p class="text-sm text-secondary leading-relaxed">
          Building companies and choosing love over fear. Much love.
        </p>
        <a
          href="https://lovenotfear.com"
          target="_blank"
          rel="noopener"
          class="inline-block mt-5 hover:opacity-80 transition-opacity"
          aria-label="Love Not Fear"
        >
          <img src="/logos/companies/lovenotfear.png" alt="Love Not Fear" class="h-14 w-14" width="56" height="56" loading="lazy" />
        </a>
      </div>

      <div class="flex flex-col gap-8 sm:flex-row sm:gap-16">
        <div>
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary/70 mb-4">Site</p>
          <ul class="space-y-2.5">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-secondary hover:text-foreground transition-colors">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary/70 mb-4">Elsewhere</p>
          <ul class="space-y-2.5">
            <li><a href="mailto:dh@davidhenzel.com" class="text-sm text-secondary hover:text-foreground transition-colors">Email</a></li>
            <li><a href="https://twitter.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="text-sm text-secondary hover:text-foreground transition-colors">Twitter / X</a></li>
            <li><a href="https://www.linkedin.com/in/davidhenzel" target="_blank" rel="noopener noreferrer" class="text-sm text-secondary hover:text-foreground transition-colors">LinkedIn</a></li>
            <li><a href="https://www.instagram.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="text-sm text-secondary hover:text-foreground transition-colors">Instagram</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-border flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">🇩🇪 Wiesbaden · 🇺🇸 Los Angeles · 🇹🇷 Bodrum</p>
      <p class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">&copy; {year} David Henzel</p>
    </div>
  </div>
</footer>
