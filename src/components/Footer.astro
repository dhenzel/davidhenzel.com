---
import { navItems } from '../data/navigation';

interface Props {
  variant?: 'full' | 'slim';
}

const { variant = 'full' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-ink">
  {variant === 'full' && (
    <div class="grid md:grid-cols-[1.6fr_1fr_1fr] gap-8 px-6 md:px-8 py-9 border-b border-hairline">
      <div>
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-[22px] w-auto mb-3" />
        <p class="text-[13.5px] leading-relaxed text-mute max-w-[260px]">
          Building companies and choosing love over fear.
        </p>
      </div>

      <nav class="flex flex-col gap-2 text-[13.5px] text-body" aria-label="Footer navigation">
        <span class="table-label mb-1">Site</span>
        {navItems.map((item) => (
          <a href={item.href} class="hover:text-accent transition-colors">{item.label}</a>
        ))}
      </nav>

      <div class="flex flex-col gap-2 text-[13.5px] text-body">
        <span class="table-label mb-1">Elsewhere</span>
        <a href="mailto:dh@davidhenzel.com" class="hover:text-accent transition-colors">Email</a>
        <a href="https://twitter.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Twitter / X</a>
        <a href="https://www.linkedin.com/in/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn</a>
        <a href="https://www.instagram.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Instagram</a>
        <a href="https://lovenotfear.com" target="_blank" rel="noopener" class="hover:text-accent transition-colors">Love Not Fear</a>
      </div>
    </div>
  )}

  <div class="flex flex-col sm:flex-row sm:justify-between gap-1 px-6 md:px-8 py-4 text-[12.5px] text-faint">
    <span class="whitespace-nowrap">🇩🇪 Wiesbaden · 🇺🇸 Los Angeles · 🇹🇷 Bodrum</span>
    <span>&copy; {year} David Henzel</span>
  </div>
</footer>
