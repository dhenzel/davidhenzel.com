---
import { navItems } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border">
  <div class="max-w-content mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="hover:opacity-70 transition-opacity" aria-label="David Henzel — home">
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-6 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navItems.map((item) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'font-mono text-[0.72rem] uppercase tracking-[0.15em] transition-colors',
                isActive
                  ? 'text-foreground'
                  : 'text-secondary hover:text-foreground',
              ]}
            >
              {item.label}
            </a>
          );
        })}
        <a
          href="/cal"
          class="font-mono text-[0.72rem] uppercase tracking-[0.15em] text-background bg-foreground px-3.5 py-2 hover:bg-hover transition-colors"
        >
          Book a call
        </a>
      </nav>

      <!-- Mobile hamburger button -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 text-foreground"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar1"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar2"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar3"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden hidden"
      aria-label="Mobile navigation"
    >
      <nav class="pb-6 flex flex-col gap-4">
        {navItems.map((item) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'font-mono text-xs uppercase tracking-[0.15em] py-1 transition-colors',
                isActive
                  ? 'text-foreground'
                  : 'text-secondary hover:text-foreground',
              ]}
            >
              {item.label}
            </a>
          );
        })}
        <a href="/cal" class="font-mono text-xs uppercase tracking-[0.15em] py-1 text-foreground">
          Book a call →
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      bar1?.classList.add('translate-y-[7px]', 'rotate-45');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-translate-y-[7px]', '-rotate-45');
    } else {
      bar1?.classList.remove('translate-y-[7px]', 'rotate-45');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-translate-y-[7px]', '-rotate-45');
    }
  });
</script>
