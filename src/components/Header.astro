---
import { navItems } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-ink">
  <!-- Desktop: 3-col ink-ruled grid -->
  <div class="hidden md:grid grid-cols-[1fr_2fr_1fr] items-center">
    <div class="px-8 py-[18px] border-r border-ink">
      <a href="/" class="hover:opacity-70 transition-opacity" aria-label="David Henzel, home">
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-6 w-auto" />
      </a>
    </div>
    <nav class="px-8 py-[18px] border-r border-ink flex gap-6 text-[13px] font-medium" aria-label="Main navigation">
      {navItems.map((item) => {
        const isActive =
          item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'transition-colors hover:text-accent',
              isActive ? 'text-ink font-semibold' : 'text-body',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <div class="px-8 py-[18px] text-right text-[13px] font-medium">
      <a href="/cal" class="text-ink hover:text-accent transition-colors">Book a call →</a>
    </div>
  </div>

  <!-- Mobile: logo + hamburger -->
  <div class="md:hidden px-6">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="hover:opacity-70 transition-opacity" aria-label="David Henzel, home">
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-6 w-auto" />
      </a>
      <button
        id="menu-toggle"
        class="flex flex-col justify-center items-center w-8 h-8 gap-1.5 text-ink"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar1"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar2"></span>
        <span class="block w-5 h-px bg-current transition-all duration-200" id="bar3"></span>
      </button>
    </div>

    <div id="mobile-menu" class="hidden" aria-label="Mobile navigation">
      <nav class="pb-6 pt-2 flex flex-col gap-3 border-t border-hairline">
        {navItems.map((item) => {
          const isActive =
            item.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium py-1 transition-colors',
                isActive ? 'text-ink font-semibold' : 'text-body hover:text-accent',
              ]}
            >
              {item.label}
            </a>
          );
        })}
        <a href="/cal" class="text-sm font-medium py-1 text-ink">
          Book a call →
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      bar1?.classList.add('translate-y-[7px]', 'rotate-45');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-translate-y-[7px]', '-rotate-45');
    } else {
      bar1?.classList.remove('translate-y-[7px]', 'rotate-45');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-translate-y-[7px]', '-rotate-45');
    }
  });
</script>
