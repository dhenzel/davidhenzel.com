---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const outlets = [
  { name: 'Forbes', logo: '/logos/media/forbes.png' },
  { name: 'Inc.', logo: '/logos/media/inc.png' },
  { name: 'Fast Company', logo: '/logos/media/fastcompany.png' },
  { name: 'HuffPost', logo: '/logos/media/huffpost.png' },
  { name: 'YEC', logo: '/logos/media/yec.png' },
  { name: 'The Next Web', logo: '/logos/media/tnw.png' },
  { name: 'VentureBeat', logo: '/logos/media/venturebeat.png' },
];
---

<div class:list={[compact ? '' : 'py-10 border-y border-border']}>
  <p class:list={[
    'font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary/70',
    compact ? 'mb-4' : 'text-center mb-6',
  ]}>
    Featured in
  </p>
  <ul
    class:list={[
      'flex flex-wrap items-center',
      compact ? 'justify-start gap-x-8 gap-y-4' : 'justify-center gap-x-10 gap-y-6',
    ]}
    aria-label="Media outlets"
  >
    {outlets.map((outlet) => (
      <li>
        <img
          src={outlet.logo}
          alt={outlet.name}
          class:list={[
            'w-auto object-contain grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300',
            compact ? 'h-5 opacity-35' : 'h-6 opacity-40',
          ]}
          loading="lazy"
        />
      </li>
    ))}
  </ul>
</div>
