---
interface Props {
  id: string;
  compact?: boolean;
}

const { id, compact = false } = Astro.props;
---

<form class="newsletter-form" data-form-id={id}>
  <div class="flex gap-2">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 min-w-0 px-3 py-2 text-sm border-b border-border bg-transparent text-foreground placeholder-secondary/40 focus:outline-none focus:border-accent transition-colors"
    />
    <button
      type="submit"
      class="text-sm text-accent hover:text-accent/80 transition-colors underline underline-offset-3 decoration-accent/30 hover:decoration-accent shrink-0"
    >
      Subscribe
    </button>
  </div>
  <p class="newsletter-status mt-2 text-xs hidden"></p>
</form>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const btn = f.querySelector('button') as HTMLButtonElement;
      const status = f.querySelector('.newsletter-status') as HTMLElement;
      const emailInput = f.querySelector('input[name="email"]') as HTMLInputElement;
      const nameInput = f.querySelector('input[name="firstName"]') as HTMLInputElement | null;

      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      status.classList.add('hidden');

      try {
        // Collect UTM params from URL
        const params = new URLSearchParams(window.location.search);
        const utmSource = params.get('utm_source') || undefined;
        const utmMedium = params.get('utm_medium') || undefined;
        const utmCampaign = params.get('utm_campaign') || undefined;

        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput.value,
            firstName: nameInput?.value || undefined,
            formSource: f.dataset.formId,
            utmSource,
            utmMedium,
            utmCampaign,
          }),
        });

        if (res.ok) {
          status.textContent = 'You\'re in! Check your inbox.';
          status.className = 'newsletter-status mt-2 text-xs text-green-600';
          f.reset();
        } else {
          const data = await res.json();
          status.textContent = data.error || 'Something went wrong. Try again.';
          status.className = 'newsletter-status mt-2 text-xs text-red-500';
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.className = 'newsletter-status mt-2 text-xs text-red-500';
      }

      btn.disabled = false;
      btn.textContent = 'Subscribe';
    });
  });
</script>
