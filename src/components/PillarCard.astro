---
import type { Pillar } from '../data/pillars';

interface Props {
  pillar: Pillar;
  index: number;
}

const { pillar, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a
  href={`/blog?pillar=${pillar.slug}`}
  class="group block border-t border-border py-6 transition-colors"
>
  <div class="flex items-baseline gap-4">
    <span class="font-mono text-xs text-secondary/70 shrink-0 pt-1">{num}</span>
    <div class="min-w-0">
      <h3 class="font-serif text-xl md:text-2xl font-medium tracking-tight text-foreground leading-snug group-hover:text-hover transition-colors">
        {pillar.title}
      </h3>
      <p class="mt-2 text-sm text-secondary leading-relaxed max-w-xl">
        {pillar.blurb}
      </p>
      <p class="mt-3 font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">
        {pillar.venture}
      </p>
    </div>
  </div>
</a>
