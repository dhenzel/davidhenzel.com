---
import { pillars } from '../data/pillars';

interface Props {
  activePillar?: string;
}

const { activePillar } = Astro.props;
---

<nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Filter by pillar">
  <a
    href="/blog"
    class:list={[
      'text-[11px] font-medium uppercase tracking-[0.12em] pb-0.5 border-b transition-colors',
      !activePillar
        ? 'text-ink border-ink'
        : 'text-faint border-transparent hover:text-accent',
    ]}
  >
    All
  </a>
  {pillars.map((pillar) => (
    <a
      href={`/blog?pillar=${pillar.slug}`}
      class:list={[
        'text-[11px] font-medium uppercase tracking-[0.12em] pb-0.5 border-b transition-colors',
        activePillar === pillar.slug
          ? 'text-ink border-ink'
          : 'text-faint border-transparent hover:text-accent',
      ]}
    >
      {pillar.title}
    </a>
  ))}
</nav>
