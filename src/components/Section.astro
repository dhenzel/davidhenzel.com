---
interface Props {
  /** Width tier for the inner container */
  width?: 'prose' | 'content' | 'wide';
  /** Vertical padding rhythm */
  space?: 'sm' | 'md' | 'lg' | 'none';
  /** Optional muted background band (full-bleed) */
  surface?: boolean;
  /** Hairline rule along the top edge */
  divider?: boolean;
  /** Render as a specific element */
  as?: string;
  class?: string;
}

const {
  width = 'content',
  space = 'md',
  surface = false,
  divider = false,
  as = 'section',
  class: className = '',
} = Astro.props;

const widthClass = {
  prose: 'max-w-prose',
  content: 'max-w-content',
  wide: 'max-w-wide',
}[width];

const spaceClass = {
  none: '',
  sm: 'py-10 md:py-14',
  md: 'py-16 md:py-20',
  lg: 'py-20 md:py-28',
}[space];

const Tag = as as any;
---

<Tag class:list={[surface ? 'bg-muted' : '', divider ? 'border-t border-border' : '']}>
  <div class:list={[widthClass, 'mx-auto px-6', spaceClass, className]}>
    <slot />
  </div>
</Tag>
