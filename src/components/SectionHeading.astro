---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  align?: 'left' | 'center';
  as?: 'h1' | 'h2' | 'h3';
}

const { title, subtitle, eyebrow, align = 'left', as = 'h2' } = Astro.props;
const Tag = as;
const sizeClass = as === 'h1'
  ? 'text-3xl md:text-4xl'
  : 'text-2xl md:text-[1.75rem]';
---

<div class:list={['mb-10', align === 'center' ? 'text-center' : '']}>
  {eyebrow && (
    <p class:list={[
      'font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary mb-4',
    ]}>
      {eyebrow}
    </p>
  )}
  <Tag class:list={['font-serif font-medium tracking-tight text-foreground leading-[1.1]', sizeClass]}>
    {title}
  </Tag>
  {subtitle && (
    <p class:list={['mt-3 text-base text-secondary leading-relaxed max-w-xl', align === 'center' ? 'mx-auto' : '']}>
      {subtitle}
    </p>
  )}
</div>
