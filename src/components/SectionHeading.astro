---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'left' } = Astro.props;
---

<div class:list={['mb-10', align === 'center' ? 'text-center' : '']}>
  <h2 class="text-2xl font-semibold tracking-tight text-neutral-900">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 text-base text-neutral-500 max-w-xl" class:list={[align === 'center' ? 'mx-auto' : '']}>
      {subtitle}
    </p>
  )}
</div>
