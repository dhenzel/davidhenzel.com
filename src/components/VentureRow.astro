---
interface Props {
  number: string;
  name: string;
  oneLiner: string;
  tag?: string;
  tagAccent?: boolean;
  href?: string;
  last?: boolean;
}

const { number, name, oneLiner, tag, tagAccent = false, href, last = false } = Astro.props;
const Tag = href ? 'a' : 'div';
const external = href?.startsWith('http');
---

<Tag
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener' : undefined}
  class:list={[
    'group grid grid-cols-[40px_1fr] md:grid-cols-[56px_220px_1fr_110px] items-baseline gap-y-1 px-6 md:px-8 py-4',
    !last && 'border-b border-hairline',
  ]}
>
  <span class="text-faint text-xs">{number}</span>
  <span class="font-serif font-semibold text-base text-ink group-hover:text-accent transition-colors">{name}</span>
  <span class="col-start-2 md:col-start-3 text-mute text-sm leading-relaxed md:pr-6">{oneLiner}</span>
  {tag && (
    <span
      class:list={[
        'col-start-2 md:col-start-4 md:text-right text-[12.5px]',
        tagAccent ? 'text-accent' : 'text-faint',
      ]}
    >
      {tag}
    </span>
  )}
</Tag>
