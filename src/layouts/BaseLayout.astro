---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExitIntent from '../components/ExitIntent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  article?: {
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
  };
}

const { title, description, image, canonicalURL, article } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      article={article}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-[640px] mx-auto px-6">
      <slot />
    </main>
    <Footer />
    <ExitIntent />
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "1f00855df001483695bf5ea2aab1273c"}'></script>
  </body>
</html>
