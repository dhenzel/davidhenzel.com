---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  footer?: 'full' | 'slim' | 'none';
  article?: {
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
  };
}

const { title, description, image, canonicalURL, article, footer = 'full' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      article={article}
    />
  </head>
  <body>
    <div class:list={[
      'mx-auto max-w-site bg-paper sm:border-x border-ink flex flex-col',
      footer === 'none' ? 'border-b' : 'min-h-screen',
    ]}>
      <Header />
      <main class="flex-1">
        <slot />
      </main>
      {footer !== 'none' && <Footer variant={footer} />}
    </div>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "1f00855df001483695bf5ea2aab1273c"}'></script>
  </body>
</html>
