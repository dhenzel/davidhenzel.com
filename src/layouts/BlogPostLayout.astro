---
import BaseLayout from './BaseLayout.astro';
import ContextualCTA from '../components/ContextualCTA.astro';
import AuthorCard from '../components/AuthorCard.astro';
import SubscribeBand from '../components/SubscribeBand.astro';
import { pillarForTags } from '../data/pillars';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  cta?: 'newsletter' | 'lnf-course' | 'free-course' | 'community' | 'cohort' | 'retreat' | 'upcoach' | 'winback';
  readingTime: number;
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  cta,
  readingTime,
  headings = [],
  prevPost,
  nextPost,
} = Astro.props;

const pillar = pillarForTags(tags);
const tocHeadings = headings.filter((h) => h.depth === 2);
const showToc = tocHeadings.length >= 2;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title={`${title} · David Henzel`}
  description={description}
  image={heroImage}
  article={{ pubDate, updatedDate, tags }}
  footer="slim"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davidhenzel.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://davidhenzel.com/blog" },
      { "@type": "ListItem", "position": 3, "name": title }
    ]
  })} />

  <!-- Post header -->
  <header class="px-6 md:px-8 pt-14 md:pt-16 pb-12 border-b border-ink">
    <div class="flex gap-3.5 items-baseline eyebrow mb-5">
      <a href="/blog" class="text-faint hover:text-accent transition-colors normal-case tracking-[0.14em] uppercase">Blog</a>
      {pillar && (
        <>
          <span class="text-faint" aria-hidden="true">/</span>
          <a href={`/blog?pillar=${pillar.slug}`} class="hover:opacity-75 transition-opacity">{pillar.title}</a>
        </>
      )}
    </div>
    <h1 class="font-serif font-semibold text-[clamp(1.75rem,4.5vw,2.875rem)] leading-[1.15] max-w-[840px] mb-5">
      {title}
    </h1>
    {description && (
      <p class="text-[15.5px] leading-relaxed text-mute max-w-[680px] mb-5">{description}</p>
    )}
    <div class="flex flex-wrap gap-x-3 gap-y-1 text-[13.5px] text-mute">
      <span>David Henzel</span>
      <span aria-hidden="true">·</span>
      <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime} min read</span>
      {formattedUpdatedDate && (
        <>
          <span aria-hidden="true">·</span>
          <span>Updated {formattedUpdatedDate}</span>
        </>
      )}
    </div>
  </header>

  <!-- Body: TOC + article -->
  <div class:list={['grid', showToc && 'lg:grid-cols-[220px_1fr]']}>
    {showToc && (
      <aside class="hidden lg:block border-r border-hairline px-8 py-10" aria-label="Table of contents">
        <nav id="essay-toc" class="sticky top-8 flex flex-col gap-3.5 text-[13px] leading-normal">
          <span class="table-label">In this essay</span>
          {tocHeadings.map((h) => (
            <a href={`#${h.slug}`} class="toc-link text-mute hover:text-accent transition-colors">{h.text}</a>
          ))}
        </nav>
      </aside>
    )}

    <div class="py-10 md:py-12 max-w-[740px]">
      <article class="px-6 md:px-12">
        <div class="prose-content">
          <slot />
        </div>

        <!-- Contextual CTA -->
        <ContextualCTA type={cta} tags={tags} />
      </article>

      <div class="border-t border-hairline mt-10 pt-7 px-6 md:px-12">
        <AuthorCard />
      </div>
    </div>
  </div>

  <!-- Prev / Next navigation -->
  {(prevPost || nextPost) && (
    <nav class="grid sm:grid-cols-2 border-t border-ink" aria-label="Post navigation">
      {prevPost ? (
        <a href={`/blog/${prevPost.id}`} class="group block px-6 md:px-8 py-6 sm:border-r border-hairline">
          <div class="table-label mb-2.5">← Previous</div>
          <div class="font-serif font-semibold text-base text-ink group-hover:text-accent transition-colors">{prevPost.title}</div>
        </a>
      ) : (
        <div class="hidden sm:block sm:border-r border-hairline" />
      )}
      {nextPost && (
        <a href={`/blog/${nextPost.id}`} class="group block px-6 md:px-8 py-6 sm:text-right border-t sm:border-t-0 border-hairline">
          <div class="table-label mb-2.5">Next →</div>
          <div class="font-serif font-semibold text-base text-ink group-hover:text-accent transition-colors">{nextPost.title}</div>
        </a>
      )}
    </nav>
  )}

  <SubscribeBand id={`post-${cta ?? 'default'}`} />
</BaseLayout>

<script>
  // Highlight the TOC link for the section currently in view.
  const toc = document.getElementById('essay-toc');
  if (toc) {
    const links = [...toc.querySelectorAll<HTMLAnchorElement>('.toc-link')];
    const headings = links
      .map((a) => document.getElementById(decodeURIComponent(a.hash.slice(1))))
      .filter((el): el is HTMLElement => el !== null);

    let ticking = false;
    const update = () => {
      ticking = false;
      const threshold = window.innerHeight * 0.35;
      let current = -1;
      headings.forEach((h, i) => {
        if (h.getBoundingClientRect().top < threshold) current = i;
      });
      links.forEach((a, i) => {
        a.classList.toggle('toc-active', i === current);
        if (i === current) a.setAttribute('aria-current', 'true');
        else a.removeAttribute('aria-current');
      });
    };
    document.addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });
    update();
  }
</script>

<style>
  .toc-link.toc-active {
    color: var(--color-ink);
    font-weight: 500;
  }

  /* Prose styles for blog post content, tokenized, serif headings */
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3),
  .prose-content :global(h4),
  .prose-content :global(h5),
  .prose-content :global(h6) {
    font-family: var(--font-serif);
    font-weight: 600;
    font-optical-sizing: auto;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-top: 2.2em;
    margin-bottom: 0.6em;
    line-height: 1.3;
  }

  .prose-content :global(h1) { font-size: 1.75rem; }
  .prose-content :global(h2) { font-size: 1.625rem; }
  .prose-content :global(h3) { font-size: 1.25rem; }
  .prose-content :global(h4) { font-size: 1.05rem; }

  .prose-content :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-body);
    margin-bottom: 1.4em;
  }

  /* Lede: the opening paragraph reads in the serif at a larger size */
  .prose-content > :global(p:first-child) {
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-size: 1.1875rem;
    line-height: 1.7;
    color: var(--color-ink);
    margin-bottom: 1.5em;
  }

  .prose-content :global(a) {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-hairline);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .prose-content :global(a:hover) {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .prose-content :global(em) {
    font-style: italic;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin-bottom: 1.4em;
    padding-left: 1.5em;
    color: var(--color-body);
    line-height: 1.75;
  }

  .prose-content :global(ul) { list-style-type: disc; }
  .prose-content :global(ol) { list-style-type: decimal; }
  .prose-content :global(li) { margin-bottom: 0.4em; }

  /* Pull quote: ruled block, upright serif */
  .prose-content :global(blockquote) {
    border-top: 1px solid var(--color-ink);
    border-bottom: 1px solid var(--color-hairline);
    padding: 1.6em 0;
    margin: 2.2em 0;
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: 1.4rem;
    line-height: 1.4;
    color: var(--color-ink);
  }

  .prose-content :global(blockquote p) {
    margin-bottom: 0;
    color: var(--color-ink);
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .prose-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--color-tint);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-ink);
  }

  .prose-content :global(pre) {
    background-color: var(--color-tint);
    border: 1px solid var(--color-hairline);
    border-radius: 8px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin-bottom: 1.4em;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-hairline);
    margin: 2.5em 0;
  }

  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-hairline);
    margin: 2em 0;
  }

  .prose-content :global(video) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-hairline);
    margin: 2em 0;
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.4em;
    font-size: 0.9375rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    text-align: left;
    padding: 0.6em 0.9em;
    border-bottom: 1px solid var(--color-hairline);
    color: var(--color-body);
  }

  .prose-content :global(th) {
    font-weight: 600;
    color: var(--color-ink);
  }
</style>
