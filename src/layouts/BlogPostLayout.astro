---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime: number;
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  readingTime,
  prevPost,
  nextPost,
} = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={`${title} — David Henzel`} description={description}>
  <article class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <!-- Post header -->
    <header class="max-w-2xl mb-12">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {tags.map((tag) => (
            <span class="text-xs uppercase tracking-wide text-neutral-400 bg-neutral-100 px-2.5 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 leading-tight mb-5">
        {title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-neutral-400">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
      </div>
      {formattedUpdatedDate && (
        <p class="mt-2 text-xs text-neutral-400">
          Updated {formattedUpdatedDate}
        </p>
      )}
    </header>

    <!-- Post content -->
    <div class="max-w-2xl prose-content">
      <slot />
    </div>

    <!-- Prev / Next navigation -->
    {(prevPost || nextPost) && (
      <nav
        class="max-w-2xl mt-16 pt-8 border-t border-neutral-200 flex flex-col sm:flex-row justify-between gap-6"
        aria-label="Post navigation"
      >
        {prevPost ? (
          <a
            href={`/blog/${prevPost.id}`}
            class="group flex flex-col gap-1 text-sm max-w-xs"
          >
            <span class="text-xs uppercase tracking-wide text-neutral-400">← Previous</span>
            <span class="text-neutral-700 group-hover:text-neutral-900 group-hover:underline underline-offset-2 transition-colors">
              {prevPost.title}
            </span>
          </a>
        ) : (
          <div />
        )}
        {nextPost && (
          <a
            href={`/blog/${nextPost.id}`}
            class="group flex flex-col gap-1 text-sm max-w-xs sm:text-right"
          >
            <span class="text-xs uppercase tracking-wide text-neutral-400">Next →</span>
            <span class="text-neutral-700 group-hover:text-neutral-900 group-hover:underline underline-offset-2 transition-colors">
              {nextPost.title}
            </span>
          </a>
        )}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  /* Prose-like styles for blog post content */
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3),
  .prose-content :global(h4),
  .prose-content :global(h5),
  .prose-content :global(h6) {
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #171717;
    margin-top: 2em;
    margin-bottom: 0.5em;
    line-height: 1.3;
  }

  .prose-content :global(h1) { font-size: 2rem; }
  .prose-content :global(h2) { font-size: 1.5rem; }
  .prose-content :global(h3) { font-size: 1.25rem; }
  .prose-content :global(h4) { font-size: 1.1rem; }

  .prose-content :global(p) {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #404040;
    margin-bottom: 1.5em;
  }

  .prose-content :global(a) {
    color: #171717;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .prose-content :global(a:hover) {
    opacity: 0.6;
  }

  .prose-content :global(strong) {
    font-weight: 600;
    color: #171717;
  }

  .prose-content :global(em) {
    font-style: italic;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: #404040;
    line-height: 1.75;
  }

  .prose-content :global(ul) {
    list-style-type: disc;
  }

  .prose-content :global(ol) {
    list-style-type: decimal;
  }

  .prose-content :global(li) {
    margin-bottom: 0.4em;
  }

  .prose-content :global(blockquote) {
    border-left: 3px solid #e5e5e5;
    padding-left: 1.25em;
    margin: 2em 0;
    color: #525252;
    font-style: italic;
  }

  .prose-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose-content :global(code) {
    font-family: ui-monospace, 'Fira Code', monospace;
    font-size: 0.875em;
    background-color: #f5f5f5;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: #171717;
  }

  .prose-content :global(pre) {
    background-color: #f5f5f5;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin-bottom: 1.5em;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid #e5e5e5;
    margin: 2.5em 0;
  }

  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2em 0;
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 0.9375rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    text-align: left;
    padding: 0.6em 0.9em;
    border-bottom: 1px solid #e5e5e5;
  }

  .prose-content :global(th) {
    font-weight: 600;
    color: #171717;
  }
</style>
