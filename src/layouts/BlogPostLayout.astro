---
import BaseLayout from './BaseLayout.astro';
import ContextualCTA from '../components/ContextualCTA.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  cta?: 'newsletter' | 'lnf-course' | 'cohort' | 'retreat' | 'upcoach' | 'ai-operator';
  readingTime: number;
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
  relatedPosts?: { id: string; title: string; pubDate: Date }[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  cta,
  readingTime,
  prevPost,
  nextPost,
  relatedPosts = [],
} = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title={`${title} — David Henzel`}
  description={description}
  image={heroImage}
  article={{ pubDate, updatedDate, tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davidhenzel.com/" },
      { "@type": "ListItem", "position": 2, "name": "Content", "item": "https://davidhenzel.com/blog" },
      { "@type": "ListItem", "position": 3, "name": title }
    ]
  })} />
  <article class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <!-- Post header -->
    <header class="max-w-2xl mb-12">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {tags.map((tag) => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag)}`}
              class="text-xs uppercase tracking-wide text-accent bg-accent/10 px-2.5 py-1 rounded-full hover:bg-accent/20 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
      <h1 class="text-4xl font-semibold tracking-tight text-foreground leading-tight mb-5">
        {title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-secondary">
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime} min read</span>
      </div>
      {formattedUpdatedDate && (
        <p class="mt-2 text-xs text-secondary">
          Updated {formattedUpdatedDate}
        </p>
      )}
    </header>

    <!-- Hero image -->
    {heroImage && (
      <div class="max-w-2xl mb-10">
        <img
          src={heroImage}
          alt={"Article: " + title + " by David Henzel"}
          class="w-full rounded-xl border border-border"
          loading="eager"
        />
      </div>
    )}

    <!-- Post content -->
    <div class="max-w-2xl prose-content">
      <slot />
    </div>

    <!-- Contextual CTA -->
    <div class="max-w-2xl">
      <ContextualCTA type={cta} tags={tags} />
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <div class="max-w-2xl mt-12 pt-8 border-t border-border">
        <p class="text-sm font-semibold uppercase tracking-wide text-secondary mb-4">Related</p>
        <ul class="space-y-2">
          {relatedPosts.map((rp) => (
            <li class="text-sm text-secondary">
              <time datetime={rp.pubDate.toISOString()}>
                {rp.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {' '}
              <a
                href={`/blog/${rp.id}`}
                class="text-foreground hover:text-accent hover:underline underline-offset-2 transition-colors"
              >
                {rp.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Prev / Next navigation -->
    {(prevPost || nextPost) && (
      <nav
        class="max-w-2xl mt-12 pt-8 border-t border-accent/25 flex flex-col sm:flex-row justify-between gap-6"
        aria-label="Post navigation"
      >
        {prevPost ? (
          <a
            href={`/blog/${prevPost.id}`}
            class="group flex flex-col gap-1 text-sm max-w-xs"
          >
            <span class="text-xs uppercase tracking-wide text-secondary">&larr; Previous</span>
            <span class="text-foreground group-hover:text-accent group-hover:underline underline-offset-2 transition-colors">
              {prevPost.title}
            </span>
          </a>
        ) : (
          <div />
        )}
        {nextPost && (
          <a
            href={`/blog/${nextPost.id}`}
            class="group flex flex-col gap-1 text-sm max-w-xs sm:text-right"
          >
            <span class="text-xs uppercase tracking-wide text-secondary">Next &rarr;</span>
            <span class="text-foreground group-hover:text-accent group-hover:underline underline-offset-2 transition-colors">
              {nextPost.title}
            </span>
          </a>
        )}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  /* Prose-like styles for blog post content */
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3),
  .prose-content :global(h4),
  .prose-content :global(h5),
  .prose-content :global(h6) {
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #0A0A0A;
    margin-top: 2em;
    margin-bottom: 0.5em;
    line-height: 1.3;
  }

  .prose-content :global(h1) { font-size: 2rem; }
  .prose-content :global(h2) { font-size: 1.5rem; }
  .prose-content :global(h3) { font-size: 1.25rem; }
  .prose-content :global(h4) { font-size: 1.1rem; }

  .prose-content :global(p) {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #374151;
    margin-bottom: 1.5em;
  }

  .prose-content :global(a) {
    color: #10B981;
    text-decoration-color: rgba(16, 185, 129, 0.3);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .prose-content :global(a:hover) {
    opacity: 0.7;
  }

  .prose-content :global(strong) {
    font-weight: 600;
    color: #0A0A0A;
  }

  .prose-content :global(em) {
    font-style: italic;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: #374151;
    line-height: 1.75;
  }

  .prose-content :global(ul) {
    list-style-type: disc;
  }

  .prose-content :global(ol) {
    list-style-type: decimal;
  }

  .prose-content :global(li) {
    margin-bottom: 0.4em;
  }

  .prose-content :global(blockquote) {
    border-left: 3px solid #10B981;
    padding-left: 1.25em;
    margin: 2em 0;
    color: #6B7280;
    font-style: italic;
  }

  .prose-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose-content :global(code) {
    font-family: ui-monospace, 'Fira Code', monospace;
    font-size: 0.875em;
    background-color: #F3F4F6;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: #0A0A0A;
  }

  .prose-content :global(pre) {
    background-color: #F3F4F6;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin-bottom: 1.5em;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid #E5E7EB;
    margin: 2.5em 0;
  }

  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 2em 0;
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 0.9375rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    text-align: left;
    padding: 0.6em 0.9em;
    border-bottom: 1px solid #E5E7EB;
  }

  .prose-content :global(th) {
    font-weight: 600;
    color: #0A0A0A;
  }
</style>
