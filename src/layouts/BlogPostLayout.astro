---
import BaseLayout from './BaseLayout.astro';
import ContextualCTA from '../components/ContextualCTA.astro';
import { pillarForTags } from '../data/pillars';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  cta?: 'newsletter' | 'lnf-course' | 'free-course' | 'community' | 'cohort' | 'retreat' | 'upcoach' | 'winback';
  readingTime: number;
  prevPost?: { id: string; title: string } | null;
  nextPost?: { id: string; title: string } | null;
  relatedPosts?: { id: string; title: string; pubDate: Date }[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  cta,
  readingTime,
  prevPost,
  nextPost,
  relatedPosts = [],
} = Astro.props;

const pillar = pillarForTags(tags);

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title={`${title} · David Henzel`}
  description={description}
  image={heroImage}
  article={{ pubDate, updatedDate, tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://davidhenzel.com/" },
      { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://davidhenzel.com/blog" },
      { "@type": "ListItem", "position": 3, "name": title }
    ]
  })} />
  <article class="max-w-prose mx-auto px-6 pt-16 md:pt-24 pb-24">
    <!-- Post header: typographic banner -->
    <header class="mb-12">
      <div class="border border-border bg-muted/50 px-7 py-10 md:px-11 md:py-14">
        <div class="flex items-center justify-between gap-4 mb-8">
          {pillar ? (
            <a href={`/blog?pillar=${pillar.slug}`} class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-secondary hover:text-hover transition-colors">
              {pillar.title}
            </a>
          ) : (
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-secondary">Writing</span>
          )}
          <img src="/images/dh-logo.svg" alt="David Henzel" class="h-5 w-auto opacity-60 shrink-0" />
        </div>
        <h1 class="font-serif text-3xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.08]">
          {title}
        </h1>
        <p class="mt-7 font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <span aria-hidden="true"> · </span>{readingTime} min read
        </p>
      </div>
      {description && (
        <p class="mt-8 text-lg text-secondary leading-relaxed">{description}</p>
      )}
      {formattedUpdatedDate && (
        <p class="mt-3 font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">
          Updated {formattedUpdatedDate}
        </p>
      )}
    </header>

    <!-- Post content -->
    <div class="prose-content">
      <slot />
    </div>

    <!-- Contextual CTA -->
    <ContextualCTA type={cta} tags={tags} />

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <div class="mt-14 pt-8 border-t border-border">
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary mb-5">Related</p>
        <ul class="space-y-4">
          {relatedPosts.map((rp) => (
            <li>
              <a href={`/blog/${rp.id}`} class="group flex items-baseline gap-4">
                <time datetime={rp.pubDate.toISOString()} class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70 shrink-0 w-24">
                  {rp.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <span class="font-serif text-lg text-foreground group-hover:text-hover transition-colors leading-snug">
                  {rp.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Prev / Next navigation -->
    {(prevPost || nextPost) && (
      <nav
        class="mt-14 pt-8 border-t border-border flex flex-col sm:flex-row justify-between gap-6"
        aria-label="Post navigation"
      >
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="group flex flex-col gap-1.5 max-w-xs">
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">← Previous</span>
            <span class="font-serif text-base text-foreground group-hover:text-hover transition-colors">{prevPost.title}</span>
          </a>
        ) : (
          <div />
        )}
        {nextPost && (
          <a href={`/blog/${nextPost.id}`} class="group flex flex-col gap-1.5 max-w-xs sm:text-right sm:items-end">
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70">Next →</span>
            <span class="font-serif text-base text-foreground group-hover:text-hover transition-colors">{nextPost.title}</span>
          </a>
        )}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  /* Prose styles for blog post content, tokenized, serif headings */
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3),
  .prose-content :global(h4),
  .prose-content :global(h5),
  .prose-content :global(h6) {
    font-family: var(--font-serif);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
    margin-top: 1.8em;
    margin-bottom: 0.5em;
    line-height: 1.2;
  }

  .prose-content :global(h1) { font-size: 2rem; }
  .prose-content :global(h2) { font-size: 1.6rem; }
  .prose-content :global(h3) { font-size: 1.3rem; }
  .prose-content :global(h4) { font-size: 1.1rem; }

  .prose-content :global(p) {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-secondary);
    margin-bottom: 1.5em;
  }

  .prose-content :global(a) {
    color: var(--color-foreground);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .prose-content :global(a:hover) {
    color: var(--color-hover);
    text-decoration-color: var(--color-hover);
  }

  .prose-content :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }

  .prose-content :global(em) {
    font-style: italic;
  }

  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: var(--color-secondary);
    line-height: 1.75;
  }

  .prose-content :global(ul) { list-style-type: disc; }
  .prose-content :global(ol) { list-style-type: decimal; }
  .prose-content :global(li) { margin-bottom: 0.4em; }

  .prose-content :global(blockquote) {
    border-left: 2px solid var(--color-foreground);
    padding-left: 1.25em;
    margin: 2em 0;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.4;
    color: var(--color-foreground);
    font-style: italic;
  }

  .prose-content :global(blockquote p) {
    margin-bottom: 0;
    color: var(--color-foreground);
    font-size: inherit;
    line-height: inherit;
  }

  .prose-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--color-muted);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-foreground);
  }

  .prose-content :global(pre) {
    background-color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25em 1.5em;
    overflow-x: auto;
    margin-bottom: 1.5em;
  }

  .prose-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5em 0;
  }

  .prose-content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
    margin: 2em 0;
  }

  .prose-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 0.9375rem;
  }

  .prose-content :global(th),
  .prose-content :global(td) {
    text-align: left;
    padding: 0.6em 0.9em;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-secondary);
  }

  .prose-content :global(th) {
    font-weight: 600;
    color: var(--color-foreground);
  }
</style>
