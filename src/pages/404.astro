---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — David Henzel"
  description="The page you're looking for doesn't exist."
>

  <section class="max-w-5xl mx-auto px-6 pt-24 pb-32">
    <p class="text-xs uppercase tracking-widest text-secondary/60 mb-6">404</p>
    <h1 class="text-5xl font-semibold tracking-tight text-foreground mb-4 leading-tight">
      Page not found
    </h1>
    <p class="text-xl text-secondary leading-relaxed max-w-lg mb-10">
      This page doesn't exist or may have been moved. Head back home and you'll find your way.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-foreground text-background text-sm font-medium rounded-lg hover:bg-foreground/85 transition-colors"
    >
      Back to home
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </section>

</BaseLayout>
