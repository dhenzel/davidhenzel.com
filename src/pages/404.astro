---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found · David Henzel"
  description="The page you're looking for doesn't exist."
  footer="slim"
>
  <section class="px-6 md:px-8 pt-20 pb-28">
    <p class="eyebrow mb-5">404</p>
    <h1 class="font-serif font-semibold text-[clamp(2.5rem,7vw,4.5rem)] leading-[1.05] mb-6">
      Page not found.
    </h1>
    <p class="text-[15.5px] leading-relaxed text-body max-w-lg mb-9">
      This page doesn't exist or may have moved. Head back home and you'll find your way. Keep going.
    </p>
    <a href="/" class="btn-pill">Back to home →</a>
  </section>
</BaseLayout>
