---
import PreviewLayout from '../layouts/PreviewLayout.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<PreviewLayout
  title="David Henzel"
  description="Serial entrepreneur building from love not fear."
  bodyClass="bg-white text-black font-sans"
>
  <div class="max-w-xl mx-auto px-6">
    <!-- Header -->
    <header class="flex items-center justify-between pt-8 pb-32">
      <a href="/bare" class="text-sm font-medium tracking-tight hover:opacity-50 transition-opacity">David Henzel</a>
      <nav class="flex items-center gap-5 text-sm text-black/50">
        <a href="/blog" class="hover:text-black transition-colors">Writing</a>
        <a href="/companies" class="hover:text-black transition-colors">Ventures</a>
        <a href="/about" class="hover:text-black transition-colors">About</a>
      </nav>
    </header>

    <!-- Statement -->
    <section class="pb-32">
      <h1 class="text-3xl md:text-4xl font-medium tracking-tight leading-[1.25]">
        I build companies, and write about doing the work from love, not fear.
      </h1>
      <p class="mt-6 text-base text-black/60 leading-relaxed">
        Serial entrepreneur, 25+ years, one exit, a portfolio I still run. AI transformation done for
        real, culture without fear, and getting to your A-game.
      </p>
    </section>

    <!-- Writing -->
    <section class="pb-32">
      <ul>
        {latestPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group flex items-baseline justify-between gap-6 py-4 border-t border-black/10">
              <span class="text-base leading-snug group-hover:opacity-50 transition-opacity">{post.data.title}</span>
              <span class="text-xs tabular-nums text-black/40 shrink-0">{fmt(new Date(post.data.pubDate))}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="inline-block mt-6 text-sm text-black/50 hover:text-black transition-colors">All writing →</a>
    </section>

    <!-- Links -->
    <section class="pb-32 text-base">
      <p class="text-black/60 leading-relaxed">
        Building
        <a href="https://contextengine.com" target="_blank" rel="noopener" class="text-black underline underline-offset-4 decoration-black/20 hover:decoration-black transition-colors">Context Engine</a>,
        <a href="https://upcoach.com" target="_blank" rel="noopener" class="text-black underline underline-offset-4 decoration-black/20 hover:decoration-black transition-colors">upcoach</a>,
        <a href="https://ltvplus.com" target="_blank" rel="noopener" class="text-black underline underline-offset-4 decoration-black/20 hover:decoration-black transition-colors">LTVplus</a>,
        <a href="https://lovenotfear.com" target="_blank" rel="noopener" class="text-black underline underline-offset-4 decoration-black/20 hover:decoration-black transition-colors">Love Not Fear</a>,
        and <a href="/companies" class="text-black underline underline-offset-4 decoration-black/20 hover:decoration-black transition-colors">more</a>.
      </p>
    </section>

    <!-- Newsletter -->
    <section class="pb-32">
      <form class="newsletter-form flex gap-3 max-w-sm" data-form-id="bare">
        <input
          type="email"
          name="email"
          placeholder="Email for occasional letters"
          required
          class="flex-1 min-w-0 py-2 text-base border-b border-black/20 bg-transparent text-black placeholder-black/30 focus:outline-none focus:border-black transition-colors"
        />
        <button type="submit" class="text-sm text-black hover:opacity-50 transition-opacity shrink-0">Subscribe</button>
      </form>
      <p class="newsletter-status mt-2 text-xs hidden"></p>
    </section>

    <!-- Footer -->
    <footer class="py-10 text-xs text-black/40 flex justify-between">
      <span>© {new Date().getFullYear()} David Henzel</span>
      <span>Bodrum</span>
    </footer>
  </div>

  <script>
    document.querySelectorAll('.newsletter-form').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.target as HTMLFormElement;
        const btn = f.querySelector('button') as HTMLButtonElement;
        const status = f.querySelector('.newsletter-status') as HTMLElement;
        const emailInput = f.querySelector('input[name="email"]') as HTMLInputElement;
        btn.disabled = true;
        btn.textContent = 'Subscribing...';
        status.classList.add('hidden');
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: emailInput.value, formSource: f.dataset.formId }),
          });
          if (res.ok) {
            status.textContent = "You're in.";
            status.className = 'newsletter-status mt-2 text-xs text-black';
            f.reset();
          } else {
            status.textContent = 'Something went wrong. Try again.';
            status.className = 'newsletter-status mt-2 text-xs text-black/60';
          }
        } catch {
          status.textContent = 'Network error. Please try again.';
          status.className = 'newsletter-status mt-2 text-xs text-black/60';
        }
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      });
    });
  </script>
</PreviewLayout>
