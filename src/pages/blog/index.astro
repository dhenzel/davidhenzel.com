---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PillarFilter from '../../components/PillarFilter.astro';
import SubscribeBand from '../../components/SubscribeBand.astro';
import { pillarForTags } from '../../data/pillars';
import { getPublishedPosts } from '../../utils/posts';

const posts = (await getPublishedPosts())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Blog · David Henzel"
  description="Essays on building companies, self-leadership, and the Love Not Fear operating system. Occasional and practical — written from inside the portfolio."
>
  <section class="px-6 md:px-8 pt-14 md:pt-16 pb-12 border-b border-ink">
    <p class="eyebrow mb-5">Blog</p>
    <h1 class="font-serif font-semibold text-[clamp(2rem,5vw,3rem)] leading-[1.12] max-w-[820px] mb-5">
      Essays, ideas, <span class="text-faint">and things worth sharing.</span>
    </h1>
    <p class="text-[15.5px] leading-relaxed text-body max-w-[620px]">
      On building companies, self-leadership, and the Love Not Fear operating system.
      Occasional and practical — written from inside the portfolio.
    </p>

    <div class="mt-8 overflow-x-auto pb-1">
      <PillarFilter />
    </div>
  </section>

  <div class="table-label px-6 md:px-8 py-[13px] border-b border-hairline">All essays</div>

  {posts.length === 0 ? (
    <p class="px-6 md:px-8 py-8 text-sm text-body">Nothing here yet. Check back soon.</p>
  ) : (
    <div id="post-list">
      {posts.map((post) => {
        const pillar = pillarForTags(post.data.tags);
        return (
          <article class="post-item border-b border-hairline" data-pillar={pillar?.slug ?? ''}>
            <a href={`/blog/${post.id}`} class="group grid md:grid-cols-[130px_1fr_1.1fr] items-baseline gap-y-1.5 px-6 md:px-8 py-5">
              <time class="text-faint text-[12.5px]">{fmt(new Date(post.data.pubDate))}</time>
              <h2 class="font-serif font-semibold text-[17px] leading-[1.35] text-ink md:pr-7 group-hover:text-accent transition-colors">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-mute text-sm leading-relaxed">{post.data.description}</p>
              )}
            </a>
          </article>
        );
      })}
    </div>
  )}
  <p id="empty-state" class="hidden text-sm text-body px-6 md:px-8 py-8">
    No posts in this pillar yet, more coming. Meanwhile, <a href="/blog" class="ink-link">see everything</a>.
  </p>

  <SubscribeBand id="blog-index" />
</BaseLayout>

<script>
  // Client-side pillar filtering (static site, query string, not a route)
  const params = new URLSearchParams(window.location.search);
  const activePillar = params.get('pillar');

  if (activePillar) {
    // Filter posts
    const items = document.querySelectorAll<HTMLElement>('.post-item');
    let shown = 0;
    items.forEach((item) => {
      const match = item.dataset.pillar === activePillar;
      item.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    document.getElementById('empty-state')?.classList.toggle('hidden', shown > 0);

    // Highlight the active filter link
    document.querySelectorAll<HTMLAnchorElement>('nav[aria-label="Filter by pillar"] a').forEach((a) => {
      const isActive = a.getAttribute('href') === `/blog?pillar=${activePillar}`;
      if (isActive) {
        a.classList.remove('text-faint', 'border-transparent');
        a.classList.add('text-ink', 'border-ink');
      } else {
        a.classList.remove('text-ink', 'border-ink');
        a.classList.add('text-faint', 'border-transparent');
      }
    });
  }
</script>
