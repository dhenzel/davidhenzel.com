---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Content — David Henzel"
  description="Essays, ideas, and things worth sharing."
>
  <section class="pt-16">
    <h1 class="text-2xl font-semibold tracking-tight text-foreground mb-2">Content</h1>
    <p class="text-base text-secondary leading-relaxed mb-10">
      Essays, ideas, and things worth sharing.
    </p>

    {posts.length === 0 ? (
      <p class="text-sm text-secondary">Nothing here yet. Check back soon.</p>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => {
          const date = new Date(post.data.pubDate);
          const formatted = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          return (
            <article>
              <p class="text-xs text-secondary/50 mb-1">{formatted}</p>
              <a href={`/blog/${post.id}`} class="text-base font-semibold text-foreground underline underline-offset-3 decoration-accent/30 hover:text-accent hover:decoration-accent transition-colors">
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="text-sm text-secondary leading-relaxed mt-1">{post.data.description}</p>
              )}
            </article>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
