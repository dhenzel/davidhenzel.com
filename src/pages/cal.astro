---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book a Call · David Henzel"
  description="Book a 20-minute call with David Henzel. Let's talk about building companies, AI transformation, conscious leadership, or how we might work together."
>
  <section class="max-w-prose mx-auto px-6 pt-20 md:pt-28">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-secondary mb-8">Book a call</p>
    <h1 class="font-serif text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.1]">
      Let's talk.
    </h1>
    <p class="mt-6 text-lg text-secondary leading-relaxed">
      Whether it's about building companies, AI transformation, conscious leadership, or finding ways
      to work together, grab a time that works for you.
    </p>

    <div class="mt-12">
      <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-secondary mb-6">Pick a time</p>
      <div class="calendly-inline-widget" data-url="https://calendly.com/dhenzel/20min?hide_gdpr_banner=1" style="min-width:320px;height:1000px;overflow:hidden;"></div>
    </div>
  </section>

  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
</BaseLayout>
