---
import BaseLayout from '../layouts/BaseLayout.astro';
import { companies } from '../data/companies';

const focus = companies.filter((c) => c.status === 'focus');
const active = companies.filter((c) => c.status !== 'focus' && c.status !== 'exited');
const exited = companies.filter((c) => c.status === 'exited');

const activeLeft = active.filter((_, i) => i < Math.ceil(active.length / 2));
const activeRight = active.filter((_, i) => i >= Math.ceil(active.length / 2));

const stats = [
  { n: '25+', l: 'years in the arena' },
  { n: '15+', l: 'companies built' },
  { n: '500+', l: 'people across the teams' },
  { n: '2', l: 'exits' },
];
---

<BaseLayout
  title="Ventures · David Henzel"
  description="David Henzel's portfolio of companies including Context Engine, upcoach, LTVplus, Shortlist, Love Not Fear, and Dünyam Village, spanning AI, growth, and conscious leadership."
>
  <!-- Intro -->
  <section class="px-6 md:px-8 pt-14 md:pt-16 pb-12 border-b border-ink">
    <p class="eyebrow mb-5">The portfolio</p>
    <h1 class="font-serif font-semibold text-[clamp(2rem,5vw,3rem)] leading-[1.12] max-w-[820px] mb-5">
      Twenty-five years of building. <span class="text-faint">Still building.</span>
    </h1>
    <p class="text-[15.5px] leading-relaxed text-body max-w-[620px]">
      These are the companies I run, across AI, growth, and conscious leadership. Interested in any
      of them? <a href="/contact" class="accent-link">Reach out</a> and I'm happy to introduce you
      to the founder or key person on the team.
    </p>
  </section>

  <!-- Stats band -->
  <dl class="grid grid-cols-2 md:grid-cols-4 border-b border-ink">
    {stats.map((s, i) => (
      <div class:list={['px-6 md:px-8 py-6', i < stats.length - 1 && 'md:border-r border-hairline', i % 2 === 0 && 'border-r md:border-r-0', i < 2 && 'border-b md:border-b-0 border-hairline']}>
        <dt class="sr-only">{s.l}</dt>
        <dd class="font-serif font-semibold text-[28px] text-ink leading-none">{s.n}</dd>
        <dd class="mt-1.5 text-[13px] text-mute">{s.l}</dd>
      </div>
    ))}
  </dl>

  <!-- Current focus -->
  <div class="flex flex-wrap justify-between items-baseline gap-2 table-label px-6 md:px-8 py-[13px] border-b border-hairline">
    <span>01 — Current focus</span>
    <span class="text-accent">Rebuilding companies around AI</span>
  </div>
  <div class="border-b border-ink">
    {focus.map((company, i) => {
      const external = company.url.startsWith('http');
      return (
        <a
          href={company.url || undefined}
          target={external ? '_blank' : undefined}
          rel={external ? 'noopener' : undefined}
          class:list={[
            'group grid grid-cols-[40px_1fr] md:grid-cols-[56px_220px_1fr] items-baseline gap-y-1 px-6 md:px-8 py-5',
            i < focus.length - 1 && 'border-b border-hairline',
          ]}
        >
          <span class="text-faint text-xs">{String(i + 1).padStart(2, '0')}</span>
          <span class="font-serif font-semibold text-lg text-ink group-hover:text-accent transition-colors">{company.name}</span>
          <span class="col-start-2 md:col-start-3 text-mute text-sm leading-relaxed">{company.oneLiner}</span>
        </a>
      );
    })}
  </div>

  <!-- Active portfolio -->
  <div class="table-label px-6 md:px-8 py-[13px] border-b border-hairline">02 — Active portfolio</div>
  <div class="grid md:grid-cols-2 border-b border-ink">
    {[activeLeft, activeRight].map((column, colIdx) => (
      <div class:list={[colIdx === 0 && 'md:border-r border-hairline']}>
        {column.map((company, i) => {
          const external = company.url.startsWith('http');
          const isLastInColumn = i === column.length - 1;
          return (
            <a
              href={company.url || undefined}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener' : undefined}
              class:list={[
                'group flex justify-between items-baseline gap-4 px-6 md:px-8 py-3.5',
                (!isLastInColumn || colIdx === 0) && 'border-b md:border-b border-hairline',
                isLastInColumn && 'md:border-b-0',
              ]}
            >
              <span class="font-serif font-semibold text-[15px] text-ink group-hover:text-accent transition-colors">{company.name}</span>
              <span class="text-mute text-[13px] text-right">{company.oneLiner}</span>
            </a>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Exits & earlier -->
  <div class="table-label px-6 md:px-8 py-[13px] border-b border-hairline">03 — Exits &amp; earlier</div>
  <div>
    {exited.map((company, i) => {
      const external = company.url?.startsWith('http');
      const Row = company.url ? 'a' : 'div';
      return (
        <Row
          href={company.url || undefined}
          target={external ? '_blank' : undefined}
          rel={external ? 'noopener' : undefined}
          class:list={[
            'group grid grid-cols-[1fr_80px] md:grid-cols-[220px_1fr_110px] items-baseline gap-y-1 px-6 md:px-8 py-4',
            i < exited.length - 1 && 'border-b border-hairline',
          ]}
        >
          <span class:list={['font-serif font-semibold text-base text-ink transition-colors', company.url && 'group-hover:text-accent']}>{company.name}</span>
          <span class="col-span-2 md:col-span-1 order-last md:order-none text-mute text-sm leading-relaxed">{company.oneLiner}</span>
          <span class:list={['md:text-right text-[12.5px]', company.tag === 'Exited' ? 'text-accent' : 'text-faint']}>{company.tag}</span>
        </Row>
      );
    })}
  </div>
</BaseLayout>
