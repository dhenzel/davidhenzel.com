---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CompanyCard from '../components/CompanyCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { companies } from '../data/companies';

const flagship = companies.filter((c) => c.status === 'flagship');
const active = companies.filter((c) => c.status !== 'flagship' && c.status !== 'exited');
const exited = companies.filter((c) => c.status === 'exited');
---

<BaseLayout
  title="Ventures · David Henzel"
  description="David Henzel's portfolio of companies including Context Engine, upcoach, LTVplus, Shortlist, Love Not Fear, and Dünyam Village, spanning AI, growth, and conscious leadership."
>
  <!-- Intro -->
  <section class="max-w-content mx-auto px-6 pt-20 md:pt-28">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-secondary mb-8">The portfolio</p>
    <h1 class="font-serif text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.1] max-w-3xl">
      A lean, alive, profitable portfolio, not a logo collection.
    </h1>
    <p class="mt-6 text-lg text-secondary leading-relaxed max-w-2xl">
      These are the companies I run, across AI, growth, and conscious leadership. They're the vehicles
      that deliver the work I write about. Interested in any of them? <a href="/contact" class="ink-link">Reach out</a> and I'm happy to introduce you to the founder or key person on the team.
    </p>
  </section>

  <!-- Flagship -->
  {flagship.length > 0 && (
    <Section width="content" space="lg">
      <SectionHeading eyebrow="Flagship" title="Where most of my energy goes." />
      <div class="border-b border-border">
        {flagship.map((company) => <CompanyCard company={company} />)}
      </div>
      <div class="mt-10 overflow-hidden" style="aspect-ratio: 16/9;">
        <iframe
          src="https://www.youtube.com/embed/WUHhTPiVTtc"
          title="David Henzel, Companies & Portfolio"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          style="width: 100%; height: 100%;"
          loading="lazy"
        ></iframe>
      </div>
    </Section>
  )}

  <!-- Active portfolio -->
  <Section width="content" space="lg" surface>
    <SectionHeading eyebrow="Active" title="The rest of the portfolio." />
    <div class="border-b border-border">
      {active.map((company) => <CompanyCard company={company} />)}
    </div>
  </Section>

  <!-- Exits / earlier -->
  {exited.length > 0 && (
    <Section width="content" space="lg">
      <SectionHeading eyebrow="Exits & earlier" title="What came before." />
      <div class="border-b border-border">
        {exited.map((company) => <CompanyCard company={company} />)}
      </div>
    </Section>
  )}

  <!-- Newsletter -->
  <Section width="prose" space="lg" surface>
    <p class="font-serif text-xl text-foreground mb-2">Follow what we're building</p>
    <p class="text-sm text-secondary mb-5">Updates on new ventures, lessons learned, and the love-not-fear work underneath it. Much love.</p>
    <NewsletterForm id="companies" />
  </Section>
</BaseLayout>
