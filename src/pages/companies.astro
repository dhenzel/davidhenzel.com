---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompanyCard from '../components/CompanyCard.astro';
import { companies } from '../data/companies';
---

<BaseLayout
  title="Companies — David Henzel"
  description="Companies built across multiple sectors over 20+ years — from SaaS to AI to conscious leadership."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 mb-4">
      Companies
    </h1>
    <p class="text-xl text-neutral-500 leading-relaxed max-w-2xl">
      Ventures built and run across multiple sectors over 20+ years — software, services, AI, and systems for conscious leadership.
    </p>
  </section>

  <!-- Companies flat list -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="flex flex-col gap-3">
      {companies.map((company) => (
        <CompanyCard company={company} />
      ))}
    </div>
  </section>

</BaseLayout>
