---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { companies } from '../data/companies';
import type { Company } from '../data/companies';

const categoryOrder: Company['category'][] = [
  'AI & Consulting',
  'SaaS',
  'B2B Services',
  'Community & Coaching',
  'Recruiting',
];

const grouped = categoryOrder.map((category) => ({
  category,
  items: companies.filter((c) => c.category === category),
}));
---

<BaseLayout
  title="Companies — David Henzel"
  description="Ten companies built across multiple sectors over 20+ years — from SaaS to AI to conscious leadership."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 mb-4">
      Companies
    </h1>
    <p class="text-xl text-neutral-500 leading-relaxed max-w-2xl">
      Ten ventures built across multiple sectors over 20+ years — software, services, AI, and systems for conscious leadership.
    </p>
  </section>

  <!-- Companies by category -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    {grouped.map(({ category, items }) => items.length > 0 && (
      <div class="mb-16">
        <SectionHeading title={category} />
        <div class="flex flex-col gap-4">
          {items.map((company) => (
            <a
              href={company.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start justify-between gap-6 p-6 border border-neutral-200 rounded-lg bg-white hover:border-neutral-400 hover:shadow-sm transition-all duration-200"
            >
              <div class="min-w-0">
                <h3 class="text-base font-semibold text-neutral-900 mb-2 group-hover:opacity-70 transition-opacity">
                  {company.name}
                </h3>
                <p class="text-sm text-neutral-500 leading-relaxed">
                  {company.description}
                </p>
              </div>
              <div class="shrink-0 mt-0.5">
                <svg
                  class="w-4 h-4 text-neutral-400 group-hover:text-neutral-700 transition-colors"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

</BaseLayout>
