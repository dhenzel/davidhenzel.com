---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompanyCard from '../components/CompanyCard.astro';
import { companies } from '../data/companies';
---

<BaseLayout
  title="Companies — David Henzel"
  description="David Henzel's portfolio of companies across SaaS, B2B services, AI consulting, and conscious leadership."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-4xl font-semibold tracking-tight text-foreground mb-4">
      Portfolio
    </h1>
    <p class="text-xl text-secondary leading-relaxed max-w-2xl mb-4">
      These are my active companies — across SaaS, B2B services, AI, and conscious leadership. I'd love to find ways to work together.
    </p>
    <p class="text-base text-secondary leading-relaxed max-w-2xl">
      Interested in any of these? <a href="/contact" class="text-accent underline underline-offset-2 hover:opacity-70 transition-opacity">Reach out</a> and I'm happy to introduce you to the founder or key person on the team.
    </p>
  </section>

  <!-- Companies flat list -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="flex flex-col gap-3">
      {companies.map((company) => (
        <CompanyCard company={company} />
      ))}
    </div>
  </section>

</BaseLayout>
