---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Contact - David Henzel"
  description="Get in touch with David Henzel. Reach out for business inquiries, speaking engagements, partnerships, or join the newsletter."
>

  <!-- Contact -->
  <section class="pt-16">
    <h1 class="text-2xl font-semibold tracking-tight text-foreground mb-4">
      Get in touch
    </h1>
    <p class="text-base text-secondary leading-relaxed mb-8">
      I read every email. For business inquiries, speaking engagements, partnerships, or just to say hello.
    </p>

    <div class="space-y-4 text-base text-secondary leading-relaxed">
      <p>
        <span class="text-foreground font-medium">Email:</span>
        <a href="mailto:dh@davidhenzel.com" class="text-accent underline underline-offset-3 decoration-accent/30 hover:decoration-accent transition-colors">dh@davidhenzel.com</a>
      </p>
      <p>
        <span class="text-foreground font-medium">Twitter:</span>
        <a href="https://twitter.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-3 decoration-accent/30 hover:decoration-accent transition-colors">@davidhenzel</a>
      </p>
      <p>
        <span class="text-foreground font-medium">LinkedIn:</span>
        <a href="https://www.linkedin.com/in/davidhenzel" target="_blank" rel="noopener noreferrer" class="text-accent underline underline-offset-3 decoration-accent/30 hover:decoration-accent transition-colors">linkedin.com/in/davidhenzel</a>
      </p>
      <p>
        <span class="text-foreground font-medium">Speaking:</span>
        <a href="/speaking" class="text-accent underline underline-offset-3 decoration-accent/30 hover:decoration-accent transition-colors">View topics and book me</a>
      </p>
    </div>
  </section>

  <hr class="border-t border-accent/25 my-12" />

  <!-- Newsletter -->
  <section>
    <p class="text-sm font-semibold text-foreground mb-1">Or just stay in the loop</p>
    <p class="text-xs text-secondary mb-4">Essays on building companies and the Love Not Fear operating system. No spam.</p>
    <NewsletterForm id="contact" compact />
  </section>

</BaseLayout>
