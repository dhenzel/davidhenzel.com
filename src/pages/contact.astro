---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — David Henzel"
  description="Get in touch with David Henzel. Reach out for business inquiries, partnerships, or join the newsletter for thoughts on building companies and the Love Not Fear framework."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <h1 class="text-5xl font-semibold tracking-tight text-neutral-900 mb-4 leading-tight">
      Get in Touch
    </h1>
    <p class="text-xl text-neutral-500 leading-relaxed max-w-xl">
      I read every email. For business inquiries, partnerships, or just to say hello — don't hesitate to reach out.
    </p>
  </section>

  <!-- Newsletter + Contact -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="max-w-lg space-y-8">

      <!-- Newsletter signup -->
      <div class="border border-neutral-200 rounded-lg p-6">
        <p class="text-xs uppercase tracking-widest text-neutral-400 mb-2">Newsletter</p>
        <p class="text-base text-neutral-600 leading-relaxed mb-4">
          Join the newsletter for thoughts on building companies, systems thinking, and the Love Not Fear operating system.
        </p>
        <!-- GHL Form Embed — replace FORM_ID_HERE with your GoHighLevel newsletter form ID -->
        <iframe
          src="https://api.leadconnectorhq.com/widget/form/FORM_ID_HERE"
          style="width:100%;height:250px;border:none;border-radius:3px"
          id="contact-newsletter"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Newsletter"
          data-layout-iframe-id="contact-newsletter"
          data-form-id="FORM_ID_HERE"
          title="Newsletter signup"
        ></iframe>
        <script src="https://link.msgsndr.com/js/form_embed.js"></script>
      </div>

      <!-- Email -->
      <div class="border border-neutral-200 rounded-lg p-6 hover:border-neutral-400 transition-colors">
        <p class="text-xs uppercase tracking-widest text-neutral-400 mb-2">Email</p>
        <a
          href="mailto:dh@davidhenzel.com"
          class="text-xl font-medium text-neutral-900 hover:opacity-60 transition-opacity"
        >
          dh@davidhenzel.com
        </a>
      </div>

      <!-- X / Twitter -->
      <div class="border border-neutral-200 rounded-lg p-6 hover:border-neutral-400 transition-colors">
        <p class="text-xs uppercase tracking-widest text-neutral-400 mb-2">X / Twitter</p>
        <a
          href="https://twitter.com/davidhenzel"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xl font-medium text-neutral-900 hover:opacity-60 transition-opacity"
        >
          @davidhenzel
        </a>
      </div>

      <!-- LinkedIn -->
      <div class="border border-neutral-200 rounded-lg p-6 hover:border-neutral-400 transition-colors">
        <p class="text-xs uppercase tracking-widest text-neutral-400 mb-2">LinkedIn</p>
        <a
          href="https://www.linkedin.com/in/davidhenzel"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xl font-medium text-neutral-900 hover:opacity-60 transition-opacity"
        >
          linkedin.com/in/davidhenzel
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
