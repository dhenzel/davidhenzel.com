---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const methods = [
  { label: 'Email', value: 'dh@davidhenzel.com', href: 'mailto:dh@davidhenzel.com' },
  { label: 'Book a call', value: 'Grab a time on my calendar', href: '/cal' },
  { label: 'Twitter / X', value: '@davidhenzel', href: 'https://twitter.com/davidhenzel' },
  { label: 'LinkedIn', value: 'linkedin.com/in/davidhenzel', href: 'https://www.linkedin.com/in/davidhenzel' },
  { label: 'Speaking', value: 'View topics and book me', href: '/speaking' },
];
---

<BaseLayout
  title="Contact — David Henzel"
  description="Get in touch with David Henzel — business inquiries, speaking engagements, partnerships, or just to say hello. I read every email."
>
  <!-- Contact -->
  <section class="max-w-prose mx-auto px-6 pt-20 md:pt-28">
    <p class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-secondary mb-8">Contact</p>
    <h1 class="font-serif text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.1]">
      Get in touch.
    </h1>
    <p class="mt-6 text-lg text-secondary leading-relaxed">
      I read every email. For business inquiries, speaking engagements, partnerships, or just to say
      hello.
    </p>

    <ul class="mt-10">
      {methods.map((m) => (
        <li class="border-t border-border last:border-b">
          <a
            href={m.href}
            target={m.href.startsWith('http') ? '_blank' : undefined}
            rel={m.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="group flex items-baseline justify-between gap-6 py-5"
          >
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-secondary/70 w-28 shrink-0">{m.label}</span>
            <span class="flex-1 text-base text-foreground group-hover:text-hover transition-colors">{m.value}</span>
            <span class="text-secondary/50 group-hover:text-hover transition-colors" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Newsletter -->
  <Section width="prose" space="lg">
    <p class="font-serif text-xl text-foreground mb-2">Or just stay in the loop</p>
    <p class="text-sm text-secondary mb-5">Occasional letters on building companies and the love-not-fear work underneath it. No spam. Much love.</p>
    <NewsletterForm id="contact" />
  </Section>
</BaseLayout>
