---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact · David Henzel"
  description="Get in touch with David Henzel, business inquiries, speaking engagements, partnerships, or just to say hello. I read every email."
>
  <!-- Hero -->
  <section class="px-6 md:px-8 pt-14 md:pt-16 pb-12 border-b border-ink">
    <p class="eyebrow mb-5">Contact</p>
    <h1 class="font-serif font-semibold text-[clamp(2rem,5vw,3rem)] leading-[1.12] max-w-[820px] mb-5">
      Let's talk. <span class="text-faint">The fastest way is a call.</span>
    </h1>
    <p class="text-[15.5px] leading-relaxed text-body max-w-[600px]">
      Whether it's making your company AI-native, one of the ventures, speaking, or something else
      entirely — reach out and I'll get back to you. I read every email.
    </p>
  </section>

  <!-- Contact methods -->
  <div class="grid md:grid-cols-3">
    <a href="/cal" class="group block px-6 md:px-8 py-9 border-b md:border-b-0 md:border-r border-hairline">
      <div class="table-label mb-3.5">01 — Book a call</div>
      <div class="font-serif font-semibold text-xl text-ink mb-2 group-hover:text-accent transition-colors">Grab a slot on my calendar</div>
      <div class="text-sm leading-relaxed text-mute mb-4">
        For AI transformation — or if you want to partner up with one of our companies.
      </div>
      <span class="text-sm font-medium text-accent">davidhenzel.com/cal →</span>
    </a>
    <a href="mailto:dh@davidhenzel.com" class="group block px-6 md:px-8 py-9 border-b md:border-b-0 md:border-r border-hairline">
      <div class="table-label mb-3.5">02 — Email</div>
      <div class="font-serif font-semibold text-xl text-ink mb-2 group-hover:text-accent transition-colors">Write to me directly</div>
      <div class="text-sm leading-relaxed text-mute mb-4">
        For speaking requests, intros to portfolio founders, and everything else.
      </div>
      <span class="text-sm font-medium text-accent">dh@davidhenzel.com →</span>
    </a>
    <div class="px-6 md:px-8 py-9">
      <div class="table-label mb-3.5">03 — Elsewhere</div>
      <div class="font-serif font-semibold text-xl text-ink mb-2">Follow along</div>
      <div class="flex flex-col gap-2.5 text-[14.5px] text-body mt-3.5">
        <a href="https://www.linkedin.com/in/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">LinkedIn →</a>
        <a href="https://twitter.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Twitter / X →</a>
        <a href="https://www.instagram.com/davidhenzel" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Instagram →</a>
      </div>
    </div>
  </div>
</BaseLayout>
