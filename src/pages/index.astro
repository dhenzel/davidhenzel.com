---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CompanyCard from '../components/CompanyCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { companies } from '../data/companies';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="David Henzel — Builder, Coach, Recovering Introvert"
  description="David Henzel builds companies and coaches people at the intersection of technology, purpose, and conscious leadership through the Love Not Fear framework."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-12">
      <div class="max-w-xl">
        <h1 class="text-5xl font-semibold tracking-tight text-neutral-900 mb-5 leading-tight">
          Hi, I'm David.
        </h1>
        <p class="text-xl text-neutral-500 leading-relaxed mb-8">
          I build companies and coach people to lead with purpose. Through the Love Not Fear framework, I help students find their calling and entrepreneurs figure out what truly matters.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-900 text-white text-sm font-medium rounded-lg hover:bg-neutral-700 transition-colors"
        >
          More about me
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="shrink-0">
        <img
          src="/images/david-onstage.png"
          alt="David Henzel speaking on stage"
          class="w-56 h-56 md:w-72 md:h-72 rounded-xl object-cover border border-neutral-200"
        />
      </div>
    </div>
  </section>

  <!-- Featured In -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-6 py-6">
      <p class="text-xs uppercase tracking-widest text-neutral-400 shrink-0">Featured in</p>
      <div class="flex flex-wrap items-center gap-x-8 gap-y-4">
        {[
          { name: 'Forbes', logo: '/logos/media/forbes.png' },
          { name: 'Inc.', logo: '/logos/media/inc.png' },
          { name: 'Fast Company', logo: '/logos/media/fastcompany.png' },
          { name: 'HuffPost', logo: '/logos/media/huffpost.png' },
          { name: 'YEC', logo: '/logos/media/yec.png' },
          { name: 'The Next Web', logo: '/logos/media/tnw.png' },
          { name: 'VentureBeat', logo: '/logos/media/venturebeat.png' },
        ].map((outlet) => (
          <img
            src={outlet.logo}
            alt={outlet.name}
            class="h-5 w-auto object-contain grayscale opacity-30 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </div>

  <!-- Love Not Fear -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-6">Philosophy</p>
      <blockquote class="text-2xl font-medium text-neutral-900 tracking-tight leading-snug mb-6">
        "Every decision in life, you make out of love or out of fear."
      </blockquote>
      <p class="text-base text-neutral-500 leading-relaxed mb-6">
        Love Not Fear is the framework I've built my companies and life around. We help students figure out their purpose — what to study, what to do with their lives — and we help entrepreneurs get clear on what truly matters. It's about making decisions from a place of care and courage rather than anxiety and control.
      </p>
      <a
        href="/love-not-fear"
        class="inline-flex items-center gap-2 text-sm font-medium text-neutral-900 hover:opacity-60 transition-opacity"
      >
        Explore the framework
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Companies -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <SectionHeading
      title="Companies"
      subtitle="Ten ventures built over two decades — software, services, and systems for modern businesses."
    />
    <div class="flex flex-col gap-3">
      {companies.map((company) => (
        <CompanyCard company={company} />
      ))}
    </div>
    <div class="mt-8">
      <a
        href="/companies"
        class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        View all companies
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <SectionHeading
      title="Writing"
      subtitle="Thoughts on building companies, conscious leadership, and what it means to grow."
    />
    {recentPosts.length === 0 ? (
      <div class="border border-neutral-200 rounded-lg px-8 py-12 text-center bg-neutral-50">
        <p class="text-sm text-neutral-400 mb-4">Blog coming soon.</p>
        <p class="text-xs text-neutral-400">
          Essays and reflections on building companies, conscious leadership, and what it means to grow.
        </p>
      </div>
    ) : (
      <div>
        {recentPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.pubDate.toISOString()}
            excerpt={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
    )}
    <div class="mt-6">
      <a
        href="/blog"
        class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        Go to blog
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <div class="max-w-xl">
      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-4">Newsletter</p>
      <h2 class="text-2xl font-semibold tracking-tight text-neutral-900 mb-3">
        Stay in the loop
      </h2>
      <p class="text-base text-neutral-500 leading-relaxed mb-6">
        Thoughts on building companies, conscious leadership, and the Love Not Fear framework. No spam, unsubscribe anytime.
      </p>
      <!-- GHL Form Embed — replace FORM_ID_HERE with your GoHighLevel newsletter form ID -->
      <iframe
        src="https://api.leadconnectorhq.com/widget/form/FORM_ID_HERE"
        style="width:100%;height:200px;border:none;border-radius:3px"
        id="inline-newsletter"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Newsletter"
        data-layout-iframe-id="inline-newsletter"
        data-form-id="FORM_ID_HERE"
        title="Newsletter signup"
      ></iframe>
      <script src="https://link.msgsndr.com/js/form_embed.js"></script>
    </div>
  </section>

</BaseLayout>
