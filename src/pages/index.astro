---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CompanyCard from '../components/CompanyCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { companies } from '../data/companies';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="David Henzel — Entrepreneur & Systems Builder"
  description="David Henzel is an entrepreneur and systems builder. He builds companies and helps people make more decisions out of love than fear through the Love Not Fear operating system."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-12">
      <div class="max-w-xl">
        <h1 class="text-5xl font-semibold tracking-tight text-neutral-900 mb-5 leading-tight">
          Hi, I'm David.
        </h1>
        <p class="text-xl text-neutral-500 leading-relaxed mb-8">
          I'm an entrepreneur and I love building things — companies, systems, frameworks. I've built and sold countless ventures over 20+ years, but my biggest passion is helping people make more decisions out of love than fear through the <a href="https://lovenotfear.com" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">Love Not Fear</a> operating system.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-900 text-white text-sm font-medium rounded-lg hover:bg-neutral-700 transition-colors"
        >
          More about me
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="shrink-0">
        <img
          src="/images/david-onstage.png"
          alt="David Henzel speaking on stage"
          class="w-56 h-56 md:w-72 md:h-72 rounded-xl object-cover border border-neutral-200"
        />
      </div>
    </div>
  </section>

  <!-- Featured In (full-width) -->
  <div class="border-y border-neutral-100 py-8">
    <div class="flex items-center justify-center gap-x-12 gap-y-6 flex-wrap px-6">
      {[
        { name: 'Forbes', logo: '/logos/media/forbes.png' },
        { name: 'Inc.', logo: '/logos/media/inc.png' },
        { name: 'Fast Company', logo: '/logos/media/fastcompany.png' },
        { name: 'HuffPost', logo: '/logos/media/huffpost.png' },
        { name: 'YEC', logo: '/logos/media/yec.png' },
        { name: 'The Next Web', logo: '/logos/media/tnw.png' },
        { name: 'VentureBeat', logo: '/logos/media/venturebeat.png' },
      ].map((outlet) => (
        <img
          src={outlet.logo}
          alt={outlet.name}
          class="h-6 w-auto object-contain grayscale opacity-30 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          loading="lazy"
        />
      ))}
    </div>
  </div>

  <!-- The Operating System -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-6">The operating system</p>
      <blockquote class="text-2xl font-medium text-neutral-900 tracking-tight leading-snug mb-6">
        "Every decision in life, you make out of love or out of fear."
      </blockquote>
      <p class="text-base text-neutral-500 leading-relaxed mb-4">
        <a href="https://lovenotfear.com" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">Love Not Fear</a> is the operating system I've built for living and leading with purpose. It's a four-pillar system — find your purpose, define your values, craft your vision, build your habits — designed to help people make better decisions and live a better life.
      </p>
      <p class="text-base text-neutral-500 leading-relaxed mb-6">
        We help <a href="https://lovenotfear.com/students" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">students</a> figure out what to study and what to do with their lives. We help <a href="https://lovenotfear.com/entrepreneurs" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">entrepreneurs</a> get clear on what they actually want. We work with <a href="https://lovenotfear.com" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">individuals</a> who want to live more intentionally. And we help <a href="https://lnfpeople.com" target="_blank" rel="noopener" class="text-neutral-900 underline underline-offset-2 hover:opacity-60 transition-opacity">companies</a> build teams rooted in purpose and values.
      </p>
    </div>
  </section>

  <!-- Companies -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <SectionHeading
      title="Companies"
      subtitle="Some of my current ventures — software, services, and systems for helping people work and live better."
    />
    <div class="flex flex-col gap-3">
      {companies.map((company) => (
        <CompanyCard company={company} />
      ))}
    </div>
    <div class="mt-8">
      <a
        href="/companies"
        class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        View all companies
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <SectionHeading
      title="Writing"
      subtitle="Thoughts on building companies, systems, and what it means to grow."
    />
    {recentPosts.length === 0 ? (
      <div class="border border-neutral-200 rounded-lg px-8 py-12 text-center bg-neutral-50">
        <p class="text-sm text-neutral-400 mb-4">Blog coming soon.</p>
        <p class="text-xs text-neutral-400">
          Essays and reflections on building companies, conscious leadership, and what it means to grow.
        </p>
      </div>
    ) : (
      <div>
        {recentPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            date={post.data.pubDate.toISOString()}
            excerpt={post.data.description}
            slug={post.id}
          />
        ))}
      </div>
    )}
    <div class="mt-6">
      <a
        href="/blog"
        class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        Go to blog
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <div class="max-w-xl">
      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-4">Newsletter</p>
      <h2 class="text-2xl font-semibold tracking-tight text-neutral-900 mb-3">
        Stay in the loop
      </h2>
      <p class="text-base text-neutral-500 leading-relaxed mb-6">
        Thoughts on building companies, systems thinking, and the Love Not Fear operating system. No spam, unsubscribe anytime.
      </p>
      <NewsletterForm id="home" />
    </div>
  </section>

</BaseLayout>
