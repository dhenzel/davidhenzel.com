---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CompanyCard from '../components/CompanyCard.astro';
import MediaLogos from '../components/MediaLogos.astro';
import { companies } from '../data/companies';
---

<BaseLayout
  title="David Henzel — Entrepreneur & Founder"
  description="David Henzel is a serial entrepreneur and founder building companies at the intersection of people, technology, and conscious leadership."
>

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-12">
      <div class="max-w-xl">
        <h1 class="text-5xl font-semibold tracking-tight text-neutral-900 mb-5 leading-tight">
          Hi, I'm David.
        </h1>
        <p class="text-xl text-neutral-500 leading-relaxed mb-8">
          Serial entrepreneur and founder. I build companies that help people work better, grow faster, and lead with purpose. Across 10 ventures — from SaaS to AI to conscious leadership.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-neutral-900 text-white text-sm font-medium rounded-lg hover:bg-neutral-700 transition-colors"
        >
          More about me
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Headshot placeholder -->
      <div class="shrink-0">
        <div
          class="w-48 h-48 md:w-56 md:h-56 rounded-full bg-neutral-100 border border-neutral-200 flex items-center justify-center"
          aria-label="David Henzel headshot placeholder"
        >
          <svg class="w-16 h-16 text-neutral-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured In -->
  <div class="max-w-5xl mx-auto px-6">
    <MediaLogos />
  </div>

  <!-- Companies -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <SectionHeading
      title="Companies"
      subtitle="Ten ventures built over two decades — software, services, and systems for modern businesses."
    />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {companies.map((company) => (
        <CompanyCard company={company} />
      ))}
    </div>
    <div class="mt-8">
      <a
        href="/companies"
        class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        View all companies
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <SectionHeading
      title="Writing"
      subtitle="Thoughts on entrepreneurship, leadership, and building companies."
    />
    <div class="border border-neutral-200 rounded-lg px-8 py-12 text-center bg-neutral-50">
      <p class="text-sm text-neutral-400 mb-4">Blog coming soon.</p>
      <p class="text-xs text-neutral-400">
        Essays and reflections on building companies, conscious leadership, and what it means to grow.
      </p>
    </div>
    <div class="mt-6">
      <a
        href="/blog"
        class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors inline-flex items-center gap-1.5"
      >
        Go to blog
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Love Not Fear Teaser -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-t border-neutral-100">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-neutral-400 mb-6">Philosophy</p>
      <blockquote class="text-2xl font-medium text-neutral-900 tracking-tight leading-snug mb-6">
        "Lead with love, not fear."
      </blockquote>
      <p class="text-base text-neutral-500 leading-relaxed mb-6">
        Love Not Fear is the framework I've built my companies and life around. It's about making decisions from a place of care and courage rather than anxiety and control — in business, in leadership, and in how we show up for the people around us.
      </p>
      <a
        href="/love-not-fear"
        class="inline-flex items-center gap-2 text-sm font-medium text-neutral-900 hover:opacity-60 transition-opacity"
      >
        Explore the framework
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
