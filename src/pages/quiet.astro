---
import PreviewLayout from '../layouts/PreviewLayout.astro';
import { getCollection } from 'astro:content';
import { pillars } from '../data/pillars';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const ventures = [
  { name: 'Context Engine', url: 'https://contextengine.com' },
  { name: 'upcoach', url: 'https://upcoach.com' },
  { name: 'LTVplus', url: 'https://ltvplus.com' },
  { name: 'Shortlist', url: 'https://shortlist.io' },
  { name: 'Love Not Fear', url: 'https://lovenotfear.com' },
  { name: 'Dünyam Village', url: 'https://dunyamvillage.com' },
];
---

<PreviewLayout
  title="David Henzel"
  description="Serial entrepreneur building from love not fear."
>
  <div class="max-w-2xl mx-auto px-6">
    <!-- Header -->
    <header class="flex items-center justify-between pt-10 pb-24">
      <a href="/quiet" class="hover:opacity-60 transition-opacity">
        <img src="/images/dh-logo.svg" alt="David Henzel" class="h-5 w-auto" />
      </a>
      <nav class="flex items-center gap-6 text-sm text-secondary">
        <a href="/blog" class="hover:text-foreground transition-colors">Writing</a>
        <a href="/companies" class="hover:text-foreground transition-colors">Ventures</a>
        <a href="/about" class="hover:text-foreground transition-colors">About</a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="pb-28">
      <h1 class="font-serif text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.15]">
        I build companies, and I write about doing the work from love, not fear.
      </h1>
      <p class="mt-8 text-lg text-secondary leading-relaxed">
        Serial entrepreneur, 25+ years, one exit, a portfolio I still run today. I write from inside
        the arena — AI transformation done for real, culture without fear, and getting yourself to your
        A-game.
      </p>
    </section>

    <!-- Writing -->
    <section class="pb-28">
      <p class="text-sm text-secondary mb-8">Writing</p>
      <ul class="space-y-7">
        {latestPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block">
              <span class="font-serif text-xl md:text-2xl font-medium tracking-tight text-foreground leading-snug group-hover:text-hover transition-colors">
                {post.data.title}
              </span>
              <span class="block mt-1 text-sm text-secondary/70">{fmt(new Date(post.data.pubDate))}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-9">
        <a href="/blog" class="text-sm text-foreground hover:text-hover transition-colors">All writing →</a>
      </p>
    </section>

    <!-- Pillars, as plain text -->
    <section class="pb-28">
      <p class="text-sm text-secondary mb-8">What I write about</p>
      <ul class="space-y-2.5">
        {pillars.map((p) => (
          <li>
            <a href={`/blog?pillar=${p.slug}`} class="font-serif text-lg text-foreground hover:text-hover transition-colors">
              {p.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Ventures, inline -->
    <section class="pb-28">
      <p class="text-sm text-secondary mb-8">The portfolio</p>
      <p class="text-lg leading-loose">
        {ventures.map((v, i) => (
          <>
            <a href={v.url} target="_blank" rel="noopener" class="font-serif text-foreground hover:text-hover transition-colors">{v.name}</a>{i < ventures.length - 1 ? <span class="text-secondary/40">, </span> : null}
          </>
        ))}
        <span class="text-secondary/40">, </span>
        <a href="/companies" class="text-sm text-secondary hover:text-foreground transition-colors align-middle">and more →</a>
      </p>
    </section>

    <!-- Newsletter -->
    <section class="pb-28">
      <p class="font-serif text-xl text-foreground mb-4">Occasional letters from the arena. Much love.</p>
      <form class="newsletter-form flex gap-3 max-w-md" data-form-id="quiet">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 min-w-0 py-2 text-base border-b border-border bg-transparent text-foreground placeholder-secondary/40 focus:outline-none focus:border-foreground transition-colors"
        />
        <button type="submit" class="text-sm text-foreground hover:text-hover transition-colors shrink-0">Subscribe</button>
      </form>
      <p class="newsletter-status mt-2 text-xs hidden"></p>
    </section>

    <!-- Footer -->
    <footer class="py-12 text-sm text-secondary/60">
      <p>© {new Date().getFullYear()} David Henzel · Bodrum</p>
    </footer>
  </div>

  <script>
    document.querySelectorAll('.newsletter-form').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.target as HTMLFormElement;
        const btn = f.querySelector('button') as HTMLButtonElement;
        const status = f.querySelector('.newsletter-status') as HTMLElement;
        const emailInput = f.querySelector('input[name="email"]') as HTMLInputElement;
        btn.disabled = true;
        btn.textContent = 'Subscribing...';
        status.classList.add('hidden');
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: emailInput.value, formSource: f.dataset.formId }),
          });
          if (res.ok) {
            status.textContent = "You're in! Check your inbox.";
            status.className = 'newsletter-status mt-2 text-xs text-foreground';
            f.reset();
          } else {
            status.textContent = 'Something went wrong. Try again.';
            status.className = 'newsletter-status mt-2 text-xs text-hover';
          }
        } catch {
          status.textContent = 'Network error. Please try again.';
          status.className = 'newsletter-status mt-2 text-xs text-hover';
        }
        btn.disabled = false;
        btn.textContent = 'Subscribe';
      });
    });
  </script>
</PreviewLayout>
