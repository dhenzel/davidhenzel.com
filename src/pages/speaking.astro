---
import BaseLayout from '../layouts/BaseLayout.astro';

const topics = [
  {
    title: 'AI Transformation Is Real Work, Not a Magic Trick',
    body: 'Why most of what you\'re sold is theater, and what real, operator-grade AI transformation actually takes. The demo is easy; production is hard. Measured in adoption and proven value, not an impressive rig nobody opens two months later.',
  },
  {
    title: 'Building the AI-Native Company',
    body: 'How to rebuild an organization on AI, better systems, and a context layer, live, from someone running a real portfolio, not selling a course about it.',
  },
  {
    title: 'Culture Without Fear',
    body: 'How to build a company where people do their best work out of love, not fear. Hiring, firing, and running teams from a place that isn\'t hustle and grind.',
  },
  {
    title: 'From Introvert to CEO',
    body: 'The story of a self-described recovering introvert who built and sold companies, and how self-awareness, not bravado, became the real competitive advantage.',
  },
  {
    title: 'Your Personal Operating System',
    body: 'A practical framework for getting clear on who you are and what you want (vision, mission, values, goals, habits), and putting your own agent to work on your life, not just your company.',
  },
  {
    title: 'For Universities: Helping Students Find Their Path',
    body: 'Helping young people figure out what they actually want to do, what to study, and how to build a foundation of self-awareness before the world tells them who to be.',
  },
];

const appearances = [
  { name: 'Forbes, Guest Contributor', url: 'https://www.forbes.com/councils/theyec/2022/04/13/10-ways-to-balance-what-customers-want-with-whats-best-for-business/' },
  { name: 'Entrepreneurs on Fire, with John Lee Dumas', url: 'https://www.eofire.com/podcast/davidhenzel/' },
  { name: 'Growth Everywhere, with Eric Siu', url: 'https://www.levelingup.com/growth-everywhere-interview/david-henzel-managing-happiness/' },
  { name: 'Predictable Profits Podcast', url: 'https://predictableprofits.com/david-henzel-podcast/' },
  { name: 'Consulting Success Podcast', url: 'https://www.consultingsuccess.com/how-to-manage-yourself-out-of-your-consulting-business-with-david-henzel' },
  { name: 'How We Solve Podcast', url: 'https://howwesolve.com/podcast/e1-david-henzel-mission-vision-values/' },
  { name: "Entrepreneurs' Organization (EO), Member & Speaker" },
  { name: 'Marketing Speak, with Stephan Spencer' },
  { name: 'Radical Responsibility, with Fleet Maull' },
  { name: 'The Startup Chat, Multiple Appearances' },
  { name: 'Running Remote, Future of Distributed Teams' },
  { name: 'SaaStock, Building Companies with Purpose' },
  { name: 'SEED Slovenia' },
  { name: 'University guest lectures, Self-Leadership for Students' },
  { name: 'Corporate workshops & webinars, Love Not Fear for Teams' },
];

const half = Math.ceil(appearances.length / 2);
const appearancesLeft = appearances.slice(0, half);
const appearancesRight = appearances.slice(half);
---

<BaseLayout
  title="Speaking · David Henzel"
  description="Book David Henzel to speak. Topics include doing AI transformation for real, building culture without fear, from introvert to CEO, and building your personal operating system."
>
  <!-- Hero -->
  <section class="grid md:grid-cols-[1fr_400px] border-b border-ink">
    <div class="px-6 md:px-8 pt-14 md:pt-16 pb-12 md:border-r border-ink">
      <p class="eyebrow mb-5">Speaking</p>
      <h1 class="font-serif font-semibold text-[clamp(1.875rem,4.5vw,3rem)] leading-[1.15] mb-5">
        Real stories from 25+ years of building. <span class="text-faint">On stage.</span>
      </h1>
      <p class="text-[15.5px] leading-relaxed text-body max-w-[560px]">
        I speak about doing AI transformation for real, building companies from a place of love, and
        the systems that help people find their purpose. Keynote, workshop, webinar, podcast, or
        university lecture — I bring what I'm actually building and running, not theory from the
        sidelines.
      </p>
    </div>
    <div class="relative min-h-[300px] md:min-h-[380px] border-t md:border-t-0 border-hairline grayscale hover:grayscale-0 transition-[filter] duration-500">
      <img
        src="/images/david-onstage.png"
        alt="David Henzel speaking on stage"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
    </div>
  </section>

  <!-- CTA band -->
  <div class="grid md:grid-cols-[1.4fr_1fr] border-b border-ink">
    <div class="px-6 md:px-8 py-7 md:border-r border-ink text-[15px] leading-relaxed text-body">
      Available for keynotes, workshops, webinars, podcasts, and university lectures — in person or remote.
    </div>
    <div class="px-6 md:px-8 py-7 flex items-center justify-between gap-4 border-t border-hairline md:border-t-0">
      <span class="text-sm font-medium text-ink">Interested?</span>
      <a href="mailto:dh@davidhenzel.com?subject=Speaking%20Inquiry" class="btn-pill">Email me</a>
    </div>
  </div>

  <!-- Talk topics -->
  <div class="table-label px-6 md:px-8 py-[13px] border-b border-hairline">01 — Talk topics</div>
  <div class="border-b border-ink">
    {topics.map((topic, i) => (
      <div class:list={['grid grid-cols-[40px_1fr] md:grid-cols-[56px_1fr_1.2fr] items-baseline gap-y-1.5 px-6 md:px-8 py-5', i < topics.length - 1 && 'border-b border-hairline']}>
        <span class="text-faint text-xs">{String(i + 1).padStart(2, '0')}</span>
        <h3 class="font-serif font-semibold text-[17px] leading-[1.35] text-ink md:pr-7">{topic.title}</h3>
        <p class="col-start-2 md:col-start-3 text-mute text-sm leading-relaxed">{topic.body}</p>
      </div>
    ))}
  </div>

  <!-- Past appearances -->
  <div class="table-label px-6 md:px-8 py-[13px] border-b border-hairline">02 — Past appearances</div>
  <div class="grid md:grid-cols-2">
    {[appearancesLeft, appearancesRight].map((column, colIdx) => (
      <ul class:list={['px-6 md:px-8 py-6 flex flex-col gap-2.5 text-[14.5px] text-body', colIdx === 0 && 'md:border-r border-hairline', colIdx === 1 && 'border-t md:border-t-0 border-hairline']}>
        {column.map((a) => (
          <li>
            {a.url ? (
              <a href={a.url} target="_blank" rel="noopener" class="ink-link">{a.name}</a>
            ) : (
              a.name
            )}
          </li>
        ))}
      </ul>
    ))}
  </div>
</BaseLayout>
