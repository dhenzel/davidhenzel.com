---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';

const topics = [
  {
    title: 'AI Transformation Is Real Work, Not a Magic Trick',
    body: 'Why most of what you\'re sold is theater — and what real, operator-grade AI transformation actually takes. The demo is easy; production is hard. Measured in adoption and proven value, not an impressive rig nobody opens two months later.',
  },
  {
    title: 'Building the AI-Native Company',
    body: 'How to rebuild an organization on AI, better systems, and a context layer — live, from someone running a real portfolio, not selling a course about it.',
  },
  {
    title: 'Culture Without Fear',
    body: 'How to build a company where people do their best work out of love, not fear. Hiring, firing, and running teams from a place that isn\'t hustle and grind.',
  },
  {
    title: 'From Introvert to CEO',
    body: 'The story of a self-described recovering introvert who built and sold companies, and how self-awareness — not bravado — became the real competitive advantage.',
  },
  {
    title: 'Your Personal Operating System',
    body: 'A practical framework for getting clear on who you are and what you want — vision, mission, values, goals, habits — and putting your own agent to work on your life, not just your company.',
  },
  {
    title: 'For Universities: Helping Students Find Their Path',
    body: 'Helping young people figure out what they actually want to do, what to study, and how to build a foundation of self-awareness before the world tells them who to be.',
  },
];

const appearances = [
  "Entrepreneurs' Organization (EO) — Member & Speaker",
  'Forbes Business Council — Guest Contributor',
  'Entrepreneur on Fire Podcast',
  'Marketing Speak Podcast by Stephan Spencer',
  'Radical Responsibility Podcast with Fleet Maull',
  'Org Design Podcast',
  'The Startup Chat Podcast — Multiple Appearances',
  'Running Remote — Future of Distributed Teams',
  'SaaStock — Building Companies with Purpose',
  'SEED Slovenia',
  'University guest lectures — Self-Leadership for Students',
  'Corporate workshops & webinars — Love Not Fear for Teams',
];
---

<BaseLayout
  title="Speaking — David Henzel"
  description="Book David Henzel to speak. Topics include doing AI transformation for real, building culture without fear, from introvert to CEO, and building your personal operating system."
>
  <!-- Intro -->
  <section class="max-w-content mx-auto px-6 pt-20 md:pt-28">
    <div class="grid md:grid-cols-5 gap-10 items-center">
      <div class="md:col-span-3">
        <p class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-secondary mb-8">Speaking</p>
        <h1 class="font-serif text-4xl md:text-5xl font-medium tracking-tight text-foreground leading-[1.1]">
          Real stories from 25+ years in the arena.
        </h1>
        <p class="mt-6 text-lg text-secondary leading-relaxed">
          I speak about doing AI transformation for real, building companies from a place of love, and
          the systems that help people find their purpose. Keynote, workshop, webinar, podcast, or
          university lecture — I bring what I'm actually building and running, not theory from the
          sidelines.
        </p>
        <p class="mt-6">
          <a href="mailto:dh@davidhenzel.com?subject=Speaking%20Inquiry" class="ink-link font-mono text-[0.72rem] uppercase tracking-[0.15em]">
            dh@davidhenzel.com →
          </a>
        </p>
      </div>
      <div class="md:col-span-2">
        <img
          src="/images/david-onstage.png"
          alt="David Henzel speaking on stage"
          class="w-full object-cover grayscale"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Talk topics -->
  <Section width="content" space="lg">
    <SectionHeading eyebrow="Talk topics" title="What I speak about." />
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-8">
      {topics.map((topic) => (
        <div class="border-t border-border pt-6">
          <h3 class="font-serif text-xl font-medium text-foreground leading-snug mb-2">{topic.title}</h3>
          <p class="text-sm text-secondary leading-relaxed">{topic.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Past appearances -->
  <Section width="content" space="lg" surface>
    <SectionHeading eyebrow="Past appearances" title="Keynotes, panels, and podcasts." />
    <ul class="grid sm:grid-cols-2 gap-x-12">
      {appearances.map((a) => (
        <li class="border-t border-border py-3 text-sm text-secondary">{a}</li>
      ))}
    </ul>
  </Section>

  <!-- CTA -->
  <Section width="prose" space="lg">
    <p class="font-serif text-2xl md:text-3xl font-medium tracking-tight text-foreground leading-tight">
      Available for keynotes, workshops, webinars, podcasts, and university lectures.
    </p>
    <p class="mt-5">
      <a href="mailto:dh@davidhenzel.com?subject=Speaking%20Inquiry" class="ink-link font-mono text-[0.72rem] uppercase tracking-[0.15em]">
        Email me → dh@davidhenzel.com
      </a>
    </p>
  </Section>
</BaseLayout>
